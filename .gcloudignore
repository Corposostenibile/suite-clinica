corposostenibile-clinica/node_modules
corposostenibile-clinica/dist
corposostenibile-clinica/.vite

# Backend local artifacts / sensitive files / backups
backend/backups
backend/uploads
backend/venv
backend/.venv
backend/__pycache__
backend/.pytest_cache
backend/.mypy_cache
backend/htmlcov
backend/.env

