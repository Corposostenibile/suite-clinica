# Frontend Environment Variables
# Copy this file to .env and fill in the values

# Loom SDK Public App ID
# Get yours at https://dev.loom.com/
VITE_LOOM_PUBLIC_APP_ID=a0db7b3b-987d-4b5f-ae28-67ca5f025c85

# Backend URL used by Vite dev proxy (local development only)
VITE_BACKEND_URL=http://127.0.0.1:5001
