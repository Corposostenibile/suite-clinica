# ─────────────────────  FEEDBACK SODDISFAZIONE  ─────────────────────
class CustomerSatisfaction(TimestampMixin, db.Model):
    """
    Singola risposta di soddisfazione (Typeform → webhook).

    • `cliente_id` = NULL  ⇒  finisce nella inbox “un-matched”  
    • alert se `satisfaction_score < 7` (gestito nei services)
    """
    __tablename__ = "customer_satisfaction"

    id = db.Column(db.BigInteger, primary_key=True)

    # — match cliente (facoltativo) —
    cliente_id = db.Column(
        db.BigInteger,
        db.ForeignKey("clienti.cliente_id", ondelete="SET NULL"),
        index=True,
    )

    # — dati anagrafici grezzi —
    first_name = db.Column(db.String(80), nullable=False)
    last_name  = db.Column(db.String(80), nullable=False)

    # — voto 1-10 —
    satisfaction_score = db.Column(db.Integer, nullable=False,
                                   comment="Scala 1-10")

    # — nuovi campi richiesti —
    matched        = db.Column(db.Boolean,  nullable=False, default=False, index=True)
    comment        = db.Column(db.Text)                 # note libere
    match_algo     = db.Column(db.String(20))           # “exact” / “trigram” / “soundex”
    typeform_token = db.Column(db.String(100), unique=True)  # idempotenza webhook
    submitted_at   = db.Column(db.DateTime, nullable=False, index=True)

    # copia JSON completa del webhook (debug / audit)
    raw_payload = db.Column(JSONB)

    __table_args__ = (
        db.CheckConstraint("satisfaction_score BETWEEN 0 AND 10",
                           name="ck_customer_satisfaction_score_range"),
    )

    # relazione → Cliente  (+overlaps per silenziare SAWarning)
    cliente = db.relationship(
        "Cliente",
        backref=db.backref(
            "satisfaction_feedback",
            lazy="selectin",
            cascade="all, delete-orphan",
            overlaps="feedback",
        ),
        overlaps="satisfaction_feedback",
    )

    # helper
    @property
    def is_alert(self) -> bool:             # score sotto soglia?
        return self.satisfaction_score < 7

    def __repr__(self):  # pragma: no cover
        cid = self.cliente_id or "NO-MATCH"
        return f"<CustomerSatisfaction {self.id} – {cid} → {self.satisfaction_score}/10>"


# ─────────────────────  KPI AGGREGATI  ───────────────────── #
class SatisfactionKPI(TimestampMixin, db.Model):
    """
    Media e volume feedback per professionista (o intero dipartimento) su
    finestre temporali roll-up (sett., mese, trimestre, anno).

    • `professional_slug`    → slug enum (es. "alice_p")  
      NULL = KPI aggregato di dipartimento.
    • la classificazione in coach / nutrizionista / psicologa
      usa `FiguraRifEnum` già registrato.
    """
    __tablename__ = "satisfaction_kpi"

    id = db.Column(db.Integer, primary_key=True)

    # periodo di riferimento (chiuso) ▼
    period_start = db.Column(db.Date, nullable=False, index=True)
    period_end   = db.Column(db.Date, nullable=False, index=True)

    # dipartimento (coach / nutrizionista / psicologa)
    category = db.Column(_def(FiguraRifEnum), nullable=False, index=True)

    # slug professionista — NULL = KPI dipartimento
    professional_slug = db.Column(db.String(50), index=True)

    # valori KPI
    avg_score       = db.Column(NUMERIC, nullable=False)
    feedback_count  = db.Column(db.Integer, nullable=False)

    __table_args__ = (
        # evita duplicati per stessa combinazione periodo+pro
        db.UniqueConstraint(
            "period_start",
            "period_end",
            "category",
            "professional_slug",
            name="uq_satisfaction_kpi_scope",
        ),
    )

    # ───────────── helper ───────────── #
    def __repr__(self):  # pragma: no cover
        who = self.professional_slug or f"{self.category.value} dept."
        return f"<SatisfactionKPI {who} {self.period_start:%Y-%m-%d}→{self.period_end:%Y-%m-%d} avg={self.avg_score:.2f}>"
    


class PostIt(TimestampMixin, db.Model):
    """
    Sticky-note virtuale personale.

    • `author_id`   FK → users.id (cascade delete)
    • Posizionamento libero (coordinate canvas)
    • Pin per tenerlo “in cima”
    """

    __tablename__ = "post_its"

    # ── PK & FK ────────────────────────────────────────────────
    id = db.Column(db.Integer, primary_key=True)
    author_id = db.Column(
        db.Integer,
        db.ForeignKey("users.id", ondelete="CASCADE"),
        nullable=False,
        index=True,
    )

    # ── Contenuto ──────────────────────────────────────────────
    content = db.Column(db.Text, nullable=False)
    color   = db.Column(db.String(7), nullable=False, default="#ffff88")   # HEX #RRGGBB
    pos_x   = db.Column(db.Float, default=0.0)    # coordinate per drag-&-drop
    pos_y   = db.Column(db.Float, default=0.0)
    is_pinned = db.Column(db.Boolean, default=False, nullable=False)

    # ── Full-text search (facoltativo) ─────────────────────────
    search_vector = db.Column(TSVECTOR)
    __ts_vector__ = TSVectorType(
        "content",
        regconfig="italian",
        weights={"content": "A"},
    )

    # ── Relazioni ──────────────────────────────────────────────
    author = relationship(
        "User",
        back_populates="post_its",
        lazy="joined",
    )

    # ── Indici extra ───────────────────────────────────────────
    __table_args__ = (
        Index(
            "ix_post_its_search_vector",
            "search_vector",
            postgresql_using="gin",
        ),
    )

    # ── Helper ────────────────────────────────────────────────
    def __repr__(self) -> str:          # pragma: no cover
        return f"<PostIt {self.id} by {self.author_id}>"



    id = db.Column(db.Integer, primary_key=True)
    phone_number = db.Column(db.String(20), unique=True, nullable=False, index=True)
    influencer_name = db.Column(db.String(255), nullable=False)
    is_active = db.Column(db.Boolean, default=True, nullable=False, index=True)
    
    # Configurazione Periskope
    periskope_phone_id = db.Column(db.String(100), unique=True)
    last_sync_at = db.Column(db.DateTime)
    
    # Statistiche cache per performance
    unread_count = db.Column(db.Integer, default=0, nullable=False)
    total_chats_count = db.Column(db.Integer, default=0, nullable=False)
    active_chats_count = db.Column(db.Integer, default=0, nullable=False)
    
    # Metadata
    avatar_url = db.Column(db.String(512))
    status_message = db.Column(db.String(255))
    
    # Relazioni
    activities = relationship(
        "ChatterActivity",
        back_populates="whatsapp_phone",
        cascade="all, delete-orphan",
        lazy="selectin"
    )
    
    notifications = relationship(
        "ChatterNotification",
        back_populates="whatsapp_phone",
        cascade="all, delete-orphan",
        lazy="selectin"
    )
    
    # Nuova relazione per quick replies
    quick_replies = relationship(
        "ChatterQuickReply",
        back_populates="whatsapp_phone",
        cascade="all, delete-orphan",
        lazy="selectin",
        order_by="ChatterQuickReply.category, ChatterQuickReply.title"
    )

    preset_audios = relationship(
        "ChatterPresetAudio",
        back_populates="whatsapp_phone",
        cascade="all, delete-orphan",
        lazy="selectin",
        order_by="ChatterPresetAudio.position, ChatterPresetAudio.title"
    )
    
    def __repr__(self) -> str:
        return f"<WhatsAppPhone {self.phone_number} - {self.influencer_name}>"



class ChatterQuickReply(TimestampMixin, db.Model):
    """
    Risposte rapide personalizzate per ogni numero WhatsApp.
    Permette ai chatter di avere template di risposta specifici per ogni influencer.
    """
    __tablename__ = "chatter_quick_replies"
    
    id = db.Column(db.Integer, primary_key=True)
    
    # Relazione con WhatsAppPhone
    phone_id = db.Column(
        db.Integer,
        db.ForeignKey("whatsapp_phones.id", ondelete="CASCADE"),
        nullable=False,
        index=True
    )
    
    # Dettagli risposta rapida
    title = db.Column(db.String(100), nullable=False)
    content = db.Column(db.Text, nullable=False)
    category = db.Column(db.String(50), default="inizio", nullable=False, index=True)
    
    # Shortcut per accesso rapido (es. /saluto, /info, etc.)
    shortcut = db.Column(db.String(50), index=True)
    
    # Statistiche utilizzo
    usage_count = db.Column(db.Integer, default=0, nullable=False)
    last_used_at = db.Column(db.DateTime)
    last_used_by_id = db.Column(db.Integer, db.ForeignKey("users.id", ondelete="SET NULL"))
    
    # Stato
    is_active = db.Column(db.Boolean, default=True, nullable=False, index=True)
    
    # Opzioni aggiuntive
    variables_enabled = db.Column(db.Boolean, default=False, nullable=False)  # Se supporta {nome}, {data}, etc.
    position = db.Column(db.Integer, default=0)  # Per ordinamento custom
    
    # Relazioni
    whatsapp_phone = relationship("WhatsAppPhone", back_populates="quick_replies")
    last_used_by = relationship("User", foreign_keys=[last_used_by_id])
    
    # Indici composti per performance
    __table_args__ = (
        # Unicità shortcut per telefono (se definito)
        Index("ix_quick_reply_phone_shortcut", "phone_id", "shortcut", unique=True),
        # Query comuni
        Index("ix_quick_reply_phone_active", "phone_id", "is_active"),
        Index("ix_quick_reply_phone_category", "phone_id", "category", "is_active"),
        # Ordinamento
        Index("ix_quick_reply_position", "phone_id", "position"),
    )
    
    @classmethod
    def get_category_choices(cls) -> list[tuple[str, str]]:
        """Ritorna le categorie disponibili per le risposte rapide."""
        return [
            ('inizio', 'Inizio'),
            ('info', 'Info'),
            ('costo', 'Costo'),
            ('non_in_target', 'Non In Target'),
            ('under', 'Under'),
            ('livello_1', 'Livello 1'),
            ('livello_2', 'Livello 2'),
            ('livello_3', 'Livello 3'),
            ('livello_4', 'Livello 4'),
            ('livello_5', 'Livello 5'),
            ('link_prenotazione', 'Link Prenotazione'),
            ('prenotazione', 'Prenotazione Effettuata'),
        ]
    
    @classmethod
    def get_category_display_name(cls, category: str) -> str:
        """Ritorna il nome display di una categoria."""
        choices = dict(cls.get_category_choices())
        return choices.get(category, category.title())
    
    @classmethod
    def get_valid_categories(cls) -> list[str]:
        """Ritorna la lista dei valori validi per le categorie."""
        return [cat[0] for cat in cls.get_category_choices()]
    
    # Validazione
    @validates('shortcut')
    def validate_shortcut(self, key, value):
        """Valida che lo shortcut sia nel formato corretto."""
        if value:
            # Rimuovi spazi e converti in lowercase
            value = value.strip().lower()
            # Assicurati che inizi con /
            if not value.startswith('/'):
                value = '/' + value
            # Rimuovi caratteri non validi
            import re
            value = re.sub(r'[^a-z0-9/_-]', '', value)
        return value
    
    @validates('category')
    def validate_category(self, key, value):
        """Normalizza e valida la categoria."""
        if value:
            # Normalizza la categoria
            normalized = value.strip().lower()
            
            # Verifica che sia una categoria valida
            valid_categories = self.get_valid_categories()
            if normalized not in valid_categories:
                # Se non è valida, usa il default
                return "inizio"
            
            return normalized
        return "inizio"
    
    def increment_usage(self, user_id: int = None) -> None:
        """Incrementa il contatore di utilizzo."""
        self.usage_count += 1
        self.last_used_at = datetime.utcnow()
        if user_id:
            self.last_used_by_id = user_id
    
    def apply_variables(self, text: str, context: dict = None) -> str:
        """
        Applica le variabili al testo se abilitate.
        
        Args:
            text: Il testo con placeholder
            context: Dizionario con i valori delle variabili
            
        Returns:
            Il testo con le variabili sostituite
        """
        if not self.variables_enabled or not context:
            return text
        
        import re
        from datetime import datetime
        
        # Variabili di default
        default_context = {
            'data': datetime.now().strftime('%d/%m/%Y'),
            'ora': datetime.now().strftime('%H:%M'),
            'giorno': datetime.now().strftime('%A'),
        }
        
        # Merge con context fornito
        full_context = {**default_context, **context}
        
        # Sostituisci le variabili
        for key, value in full_context.items():
            text = re.sub(rf'{{{key}}}', str(value), text, flags=re.IGNORECASE)
        
        return text
    
    def to_dict(self) -> dict:
        """Serializza per API JSON."""
        return {
            'id': self.id,
            'title': self.title,
            'content': self.content,
            'category': self.category,
            'category_display': self.get_category_display_name(self.category),
            'shortcut': self.shortcut,
            'usage_count': self.usage_count,
            'last_used_at': self.last_used_at.isoformat() if self.last_used_at else None,
            'is_active': self.is_active,
            'variables_enabled': self.variables_enabled,
            'position': self.position,
            'created_at': self.created_at.isoformat() if self.created_at else None,
            'updated_at': self.updated_at.isoformat() if self.updated_at else None,
        }
    
    def __repr__(self) -> str:
        return f"<ChatterQuickReply {self.shortcut or self.title} for phone {self.phone_id}>"


        
class ChatterActivity(TimestampMixin, db.Model):
    """
    Traccia tutte le attività dei chatter su WhatsApp.
    Usato per statistiche e monitoring delle performance.
    """
    __tablename__ = "chatter_activities"
    
    id = db.Column(db.Integer, primary_key=True)
    
    # Chi ha fatto l'attività
    user_id = db.Column(
        db.Integer, 
        db.ForeignKey("users.id", ondelete="CASCADE"), 
        nullable=False, 
        index=True
    )
    
    # Su quale numero
    phone_id = db.Column(
        db.Integer,
        db.ForeignKey("whatsapp_phones.id", ondelete="CASCADE"),
        nullable=False,
        index=True
    )
    phone_number = db.Column(db.String(20), nullable=False, index=True)
    
    # Dettagli chat
    chat_id = db.Column(db.String(255), nullable=False, index=True)
    chat_name = db.Column(db.String(255))
    is_group = db.Column(db.Boolean, default=False, nullable=False)
    
    # Tipo di attività
    activity_type = db.Column(
        _def(ChatterActivityTypeEnum), 
        nullable=False, 
        index=True
    )
    
    # Contenuto (per messaggi inviati)
    message_content = db.Column(db.Text)
    message_length = db.Column(db.Integer)
    has_media = db.Column(db.Boolean, default=False)
    media_type = db.Column(db.String(50))  # "image", "video", "document", etc.
    
    # Metadata Periskope
    periskope_message_id = db.Column(db.String(100), unique=True)
    periskope_queue_id = db.Column(db.String(100))
    
    # Performance metrics
    response_time_seconds = db.Column(db.Integer)  # Tempo di risposta dal messaggio precedente
    is_first_response = db.Column(db.Boolean, default=False)  # Prima risposta in conversazione
    
    # Relazioni
    user = relationship("User", back_populates="chatter_activities")
    whatsapp_phone = relationship("WhatsAppPhone", back_populates="activities")
    
    # Indici composti per query performance
    __table_args__ = (
        Index("ix_chatter_activities_daily", "user_id", "created_at"),
        Index("ix_chatter_activities_phone_chat", "phone_number", "chat_id"),
        Index("ix_chatter_activities_user_type", "user_id", "activity_type"),
    )
    
    def __repr__(self) -> str:
        return f"<ChatterActivity {self.id} - {self.activity_type.value} by User {self.user_id}>"


