class TagChatter(enum.Enum):
    """Tag fissi utilizzabili per i contatti WhatsApp gestiti dai chatter."""
    CONTRASSEGNATO = "contrassegnato"
    IN_TARGET = "in_target"
    NON_IN_TARGET = "non_in_target"
    PRENOTAZIONE_INVIATA = "prenotazione_inviata"
    PRENOTAZIONE_EFFETTUATA = "prenotazione_effettuata"
    UNDER = "under"  # NUOVO TAG
    
    @classmethod
    def values(cls) -> list[str]:
        """Ritorna la lista di tutti i valori dei tag."""
        return [tag.value for tag in cls]
    
    @classmethod
    def choices(cls) -> list[tuple[str, str]]:
        """Ritorna le scelte per form/select (value, label)."""
        return [
            (cls.CONTRASSEGNATO.value, "Contrassegnato"),
            (cls.IN_TARGET.value, "In Target"),
            (cls.PRENOTAZIONE_INVIATA.value, "Prenotazione Inviata"),
            (cls.PRENOTAZIONE_EFFETTUATA.value, "Prenotazione Effettuata"),
            (cls.UNDER.value, "Under"),
            (cls.NON_IN_TARGET.value, "Non in Target"),  # Spostato per ultimo
        ]

class ChatterContact(TimestampMixin, db.Model):
    """
    Rubrica locale dei contatti WhatsApp gestiti dai chatter.
    • `periskope_contact_id` ⇒ ID univoco restituito dall'API Periskope
    • `wa_jid` ⇒ JID WhatsApp completo (es. 39333…@c.us)
    • `display_name` ⇒ Nome visualizzato su WhatsApp (fallback)
    • `first_name` / `last_name` ⇒ Nome e Cognome compilabili dal chatter
    • `tags` ⇒ Lista di tag fissi definiti in TagChatter
    """
    __tablename__ = "chatter_contact"
    
    # ─────────────── Primary key ───────────────
    id: int = db.Column(db.Integer, primary_key=True)
    
    # ─────────────── Identificativi ───────────────
    periskope_contact_id: str = db.Column(
        db.String(64),
        nullable=False,
        unique=True,
        index=True,
    )
    wa_jid: str = db.Column(
        db.String(32),
        nullable=False,
        index=True,
        comment="Jabber ID WhatsApp (…@c.us / …@g.us)",
    )
    
    # Numero di telefono pulito (senza prefisso e @c.us)
    phone_number: str | None = db.Column(
        db.String(20),
        index=True,
        comment="Numero di telefono pulito per ricerche veloci",
    )
    
    # ─────────────── Dati anagrafici base ───────────────
    display_name: str | None = db.Column(
        db.String(255),
        comment="Nome visualizzato su WhatsApp",
    )
    first_name: str | None = db.Column(
        db.String(120),
        comment="Nome compilato dal chatter (opzionale)",
    )
    last_name: str | None = db.Column(
        db.String(120),
        comment="Cognome compilato dal chatter (opzionale)",
    )
    avatar_url: str | None = db.Column(db.String(512))
    contact_type: str | None = db.Column(
        db.String(20),
        comment="user / group / broadcast (valore Periskope)",
    )
    
    # Campo per il colore del contatto
    color_hex: str | None = db.Column(
        db.String(7),
        comment="Colore esadecimale del contatto (#RRGGBB)",
    )
    
    # ─────────────── Campi 'chatter-only' ───────────────
    label: str | None = db.Column(
        db.String(100),
        comment="Etichetta personalizzata (VIP, lead, cliente…)",
    )
    notes: str | None = db.Column(db.Text)
    is_blocked: bool = db.Column(db.Boolean, default=False, nullable=False)
    
    # Tag multipli come JSON array - solo valori da TagChatter
    tags: list[str] = db.Column(
        db.JSON,
        default=list,
        nullable=False,
        comment="Lista di tag da TagChatter enum",
    )
    
    # ─────────────── Indici utili ───────────────
    __table_args__ = (
        db.Index(
            "ix_chatter_contact_name",
            "display_name",
            postgresql_using="btree",
        ),
        db.Index(
            "ix_chatter_contact_phone",
            "phone_number",
            postgresql_using="btree",
        ),
    )
    
    # ─────────────── Helper methods ───────────────
    def has_tag(self, tag: str | TagChatter) -> bool:
        """Verifica se il contatto ha un determinato tag."""
        if isinstance(tag, TagChatter):
            tag = tag.value
        return tag in (self.tags or [])
    
    def add_tag(self, tag: str | TagChatter) -> None:
        """Aggiunge un tag se non già presente e se valido."""
        if isinstance(tag, TagChatter):
            tag = tag.value
        
        if tag not in TagChatter.values():
            raise ValueError(f"Tag '{tag}' non valido. Usa uno tra: {TagChatter.values()}")
        
        if self.tags is None:
            self.tags = []
        
        if tag not in self.tags:
            self.tags.append(tag)
            # Forza l'aggiornamento per SQLAlchemy
            db.session.execute(
                db.update(ChatterContact)
                .where(ChatterContact.id == self.id)
                .values(tags=self.tags)
            )
    
    def remove_tag(self, tag: str | TagChatter) -> None:
        """Rimuove un tag se presente."""
        if isinstance(tag, TagChatter):
            tag = tag.value
        
        if self.tags and tag in self.tags:
            self.tags.remove(tag)
            # Forza l'aggiornamento per SQLAlchemy
            db.session.execute(
                db.update(ChatterContact)
                .where(ChatterContact.id == self.id)
                .values(tags=self.tags)
            )
    
    def set_tags(self, tags: list[str | TagChatter]) -> None:
        """Imposta i tag del contatto, validando che siano tutti validi."""
        validated_tags = []
        for tag in tags:
            if isinstance(tag, TagChatter):
                validated_tags.append(tag.value)
            elif tag in TagChatter.values():
                validated_tags.append(tag)
            else:
                raise ValueError(f"Tag '{tag}' non valido. Usa uno tra: {TagChatter.values()}")
        
        self.tags = validated_tags

    
    def set_exclusive_tag(self, new_tag: str | TagChatter, exclusive_group: list[str] = None) -> None:
        """
        Imposta un tag rimuovendo automaticamente altri tag dello stesso gruppo esclusivo.
        
        Args:
            new_tag: Il nuovo tag da impostare
            exclusive_group: Lista di tag che sono mutualmente esclusivi con new_tag
                            Se None, usa il gruppo predefinito per i tag di stato
        """
        if isinstance(new_tag, TagChatter):
            new_tag = new_tag.value
        
        # Gruppo esclusivo predefinito per i tag di stato
        if exclusive_group is None:
            exclusive_group = [
                TagChatter.CONTRASSEGNATO.value,
                TagChatter.IN_TARGET.value,
                TagChatter.NON_IN_TARGET.value,
                TagChatter.UNDER.value,
                TagChatter.PRENOTAZIONE_INVIATA.value,
                TagChatter.PRENOTAZIONE_EFFETTUATA.value,
            ]
        
        # Verifica che il nuovo tag sia valido
        if new_tag not in TagChatter.values():
            raise ValueError(f"Tag '{new_tag}' non valido. Usa uno tra: {TagChatter.values()}")
        
        # Ottieni i tag attuali
        current_tags = self.tags or []
        
        # Filtra rimuovendo i tag del gruppo esclusivo
        filtered_tags = [tag for tag in current_tags if tag not in exclusive_group]
        
        # Aggiungi il nuovo tag
        filtered_tags.append(new_tag)
        
        # Imposta i nuovi tag
        self.tags = filtered_tags
        
        # Forza l'aggiornamento per SQLAlchemy
        db.session.execute(
            db.update(ChatterContact)
            .where(ChatterContact.id == self.id)
            .values(tags=self.tags)
        )
    
    def __repr__(self) -> str:  # pragma: no cover
        return f"<ChatterContact {self.display_name or self.wa_jid}>"



class ChatterFollowUp(TimestampMixin, db.Model):
   """
   Template di follow-up automatici per ogni numero WhatsApp.
   Ogni numero può avere fino a 3 follow-up che vengono inviati
   automaticamente dopo 12, 24 e 36 ore di inattività.
   """
   __tablename__ = "chatter_follow_ups"
   
   id = db.Column(db.Integer, primary_key=True)
   
   # Relazione con WhatsAppPhone
   phone_id = db.Column(
       db.Integer,
       db.ForeignKey("whatsapp_phones.id", ondelete="CASCADE"),
       nullable=False,
       index=True
   )
   
   # Numero del follow-up (1, 2 o 3)
   followup_number = db.Column(
       db.Integer,
       nullable=False,
       index=True,
       comment="Numero sequenziale del follow-up (1-3)"
   )
   
   # Contenuto del follow-up
   title = db.Column(db.String(100), nullable=False)
   content = db.Column(db.Text, nullable=False)
   
   # Configurazione
   is_active = db.Column(db.Boolean, default=True, nullable=False, index=True)
   variables_enabled = db.Column(db.Boolean, default=True, nullable=False)
   
   # Delay personalizzato (override delle 12h default)
   delay_hours = db.Column(
       db.Integer,
       default=12,
       nullable=False,
       comment="Ore di attesa prima dell'invio (default 12)"
   )
   
   # Statistiche
   usage_count = db.Column(db.Integer, default=0, nullable=False)
   success_count = db.Column(db.Integer, default=0, nullable=False)  # Quante volte ha generato risposta
   last_used_at = db.Column(db.DateTime)
   
   # Relazioni
   whatsapp_phone = relationship("WhatsAppPhone", backref="follow_ups")
   queue_entries = relationship("ChatterFollowUpQueue", back_populates="follow_up", cascade="all, delete-orphan")
   logs = relationship("ChatterFollowUpLog", back_populates="follow_up", cascade="all, delete-orphan")
   
   # Indici composti
   __table_args__ = (
       # Un solo follow-up attivo per numero e posizione
       Index("ix_followup_phone_number_active", "phone_id", "followup_number", "is_active", unique=True),
       # Query performance
       Index("ix_followup_phone_active", "phone_id", "is_active"),
       # Constraint per limitare followup_number a 1-3
       CheckConstraint("followup_number >= 1 AND followup_number <= 3", name="check_followup_number_range"),
   )
   
   def apply_variables(self, context: dict = None) -> str:
       """
       Applica le variabili al template del follow-up.
       
       Variabili disponibili:
       - {nome}: Nome del contatto
       - {telefono}: Numero di telefono
       - {ultimo_messaggio}: Preview ultimo messaggio nostro
       - {ore_passate}: Ore trascorse dall'ultimo messaggio
       - {data}: Data corrente
       - {ora}: Ora corrente
       """
       if not self.variables_enabled or not context:
           return self.content
       
       import re
       from datetime import datetime
       
       # Variabili di default
       default_context = {
           'data': datetime.now().strftime('%d/%m/%Y'),
           'ora': datetime.now().strftime('%H:%M'),
           'followup_numero': str(self.followup_number),
       }
       
       # Merge con context fornito
       full_context = {**default_context, **context}
       
       # Sostituisci le variabili
       text = self.content
       for key, value in full_context.items():
           text = re.sub(rf'{{{key}}}', str(value), text, flags=re.IGNORECASE)
       
       return text
   
   def increment_usage(self, generated_response: bool = False) -> None:
       """Incrementa i contatori di utilizzo."""
       self.usage_count += 1
       if generated_response:
           self.success_count += 1
       self.last_used_at = datetime.utcnow()
   
   def get_success_rate(self) -> float:
       """Calcola il tasso di successo (risposte generate)."""
       if self.usage_count == 0:
           return 0.0
       return (self.success_count / self.usage_count) * 100
   
   def to_dict(self) -> dict:
       """Serializza per API JSON."""
       return {
           'id': self.id,
           'phone_id': self.phone_id,
           'followup_number': self.followup_number,
           'title': self.title,
           'content': self.content,
           'is_active': self.is_active,
           'variables_enabled': self.variables_enabled,
           'delay_hours': self.delay_hours,
           'usage_count': self.usage_count,
           'success_count': self.success_count,
           'success_rate': self.get_success_rate(),
           'last_used_at': self.last_used_at.isoformat() if self.last_used_at else None,
           'created_at': self.created_at.isoformat() if self.created_at else None,
           'updated_at': self.updated_at.isoformat() if self.updated_at else None,
       }
   
   def __repr__(self) -> str:
       return f"<ChatterFollowUp {self.followup_number} for phone {self.phone_id}>"


class ChatterFollowUpQueue(TimestampMixin, db.Model):
   """
   Coda di follow-up per tracciare lo stato di ogni conversazione.
   Monitora quali conversazioni sono in attesa di follow-up e a che stadio sono.
   """
   __tablename__ = "chatter_follow_up_queue"
   
   id = db.Column(db.Integer, primary_key=True)
   
   # Identificazione conversazione
   phone_id = db.Column(
       db.Integer,
       db.ForeignKey("whatsapp_phones.id", ondelete="CASCADE"),
       nullable=False,
       index=True
   )
   phone_number = db.Column(db.String(20), nullable=False, index=True)
   
   chat_id = db.Column(db.String(255), nullable=False, index=True)
   chat_name = db.Column(db.String(255))
   
   # Contatto associato (per verificare i tag)
   contact_id = db.Column(
       db.Integer,
       db.ForeignKey("chatter_contact.id", ondelete="CASCADE"),
       nullable=False,
       index=True
   )
   
   # Ultimo messaggio nostro
   last_our_message_id = db.Column(db.String(255), nullable=False)
   last_our_message_time = db.Column(db.DateTime, nullable=False, index=True)
   last_our_message_preview = db.Column(db.String(500))
   last_our_message_by_id = db.Column(db.Integer, db.ForeignKey("users.id", ondelete="SET NULL"))
   
   # Stato follow-up
   followup_stage = db.Column(
       db.Integer,
       default=0,
       nullable=False,
       index=True,
       comment="0=no followup sent, 1-3=followup N sent"
   )
   
   # Follow-up corrente (se stage > 0)
   current_followup_id = db.Column(
       db.Integer,
       db.ForeignKey("chatter_follow_ups.id", ondelete="SET NULL")
   )
   
   # Timing
   next_followup_time = db.Column(db.DateTime, index=True)
   last_followup_sent_at = db.Column(db.DateTime)
   
   # Controllo
   is_paused = db.Column(db.Boolean, default=False, nullable=False, index=True)
   paused_at = db.Column(db.DateTime)
   paused_by_id = db.Column(db.Integer, db.ForeignKey("users.id", ondelete="SET NULL"))
   pause_reason = db.Column(db.String(255))
   
   # Se il contatto ha risposto
   contact_responded_at = db.Column(db.DateTime)
   response_message_id = db.Column(db.String(255))
   
   # Metadata
   total_followups_sent = db.Column(db.Integer, default=0, nullable=False)
   
   # Relazioni
   whatsapp_phone = relationship("WhatsAppPhone")
   contact = relationship("ChatterContact", backref="followup_queues")
   last_message_by = relationship("User", foreign_keys=[last_our_message_by_id])
   paused_by = relationship("User", foreign_keys=[paused_by_id])
   follow_up = relationship("ChatterFollowUp", back_populates="queue_entries")
   logs = relationship("ChatterFollowUpLog", back_populates="queue_entry", cascade="all, delete-orphan")
   
   # Indici composti
   __table_args__ = (
       # Una sola entry attiva per chat
       Index("ix_followup_queue_unique_chat", "phone_number", "chat_id", unique=True),
       # Query performance
       Index("ix_followup_queue_next_time", "next_followup_time", "is_paused"),
       Index("ix_followup_queue_stage", "followup_stage", "is_paused"),
       # Constraint
       CheckConstraint("followup_stage >= 0 AND followup_stage <= 3", name="check_followup_stage_range"),
   )
   
   def calculate_next_followup_time(self) -> datetime:
       """Calcola quando inviare il prossimo follow-up."""
       if self.followup_stage >= 3:
           return None  # Massimo raggiunto
       
       # Ottieni il follow-up successivo
       next_followup = ChatterFollowUp.query.filter_by(
           phone_id=self.phone_id,
           followup_number=self.followup_stage + 1,
           is_active=True
       ).first()
       
       if not next_followup:
           return None
       
       # Calcola il tempo base
       if self.followup_stage == 0:
           # Primo follow-up: dalla data dell'ultimo nostro messaggio
           base_time = self.last_our_message_time
       else:
           # Follow-up successivi: dall'ultimo follow-up inviato
           base_time = self.last_followup_sent_at or self.last_our_message_time
       
       # Aggiungi il delay
       return base_time + timedelta(hours=next_followup.delay_hours)
   
   def can_send_followup(self) -> bool:
       """Verifica se può essere inviato un follow-up."""
       if self.is_paused:
           return False
       
       if self.followup_stage >= 3:
           return False
       
       if self.contact_responded_at:
           return False
       
       if not self.next_followup_time:
           return False
       
       return datetime.utcnow() >= self.next_followup_time
   
   def validate_contact_tags(self) -> bool:
       """Verifica che il contatto abbia i tag richiesti."""
       if not self.contact:
           return False
       
       required_tags = [
           TagChatter.CONTRASSEGNATO.value,
           TagChatter.IN_TARGET.value,
           TagChatter.PRENOTAZIONE_INVIATA.value
       ]
       
       # Il contatto deve avere ALMENO UNO dei tag richiesti
       contact_tags = self.contact.tags or []
       return any(tag in contact_tags for tag in required_tags)
   
   def advance_stage(self) -> None:
       """Avanza allo stadio successivo."""
       if self.followup_stage < 3:
           self.followup_stage += 1
           self.total_followups_sent += 1
           self.last_followup_sent_at = datetime.utcnow()
           self.next_followup_time = self.calculate_next_followup_time()
   
   def reset(self, response_message_id: str = None) -> None:
       """Reset della coda quando arriva una risposta."""
       self.contact_responded_at = datetime.utcnow()
       self.response_message_id = response_message_id
       self.followup_stage = 0
       self.next_followup_time = None
       self.is_paused = False
   
   def pause(self, user_id: int, reason: str = None) -> None:
       """Mette in pausa i follow-up per questa conversazione."""
       self.is_paused = True
       self.paused_at = datetime.utcnow()
       self.paused_by_id = user_id
       self.pause_reason = reason
   
   def resume(self) -> None:
       """Riprende i follow-up per questa conversazione."""
       self.is_paused = False
       self.paused_at = None
       self.paused_by_id = None
       self.pause_reason = None
       # Ricalcola il prossimo follow-up time
       self.next_followup_time = self.calculate_next_followup_time()
   
   def to_dict(self) -> dict:
       """Serializza per API JSON."""
       return {
           'id': self.id,
           'phone_number': self.phone_number,
           'chat_id': self.chat_id,
           'chat_name': self.chat_name,
           'contact_id': self.contact_id,
           'followup_stage': self.followup_stage,
           'next_followup_time': self.next_followup_time.isoformat() if self.next_followup_time else None,
           'is_paused': self.is_paused,
           'pause_reason': self.pause_reason,
           'last_our_message_time': self.last_our_message_time.isoformat() if self.last_our_message_time else None,
           'contact_responded_at': self.contact_responded_at.isoformat() if self.contact_responded_at else None,
           'total_followups_sent': self.total_followups_sent,
           'can_send_followup': self.can_send_followup(),
           'has_valid_tags': self.validate_contact_tags(),
       }
   
   def __repr__(self) -> str:
       return f"<ChatterFollowUpQueue {self.chat_id} stage={self.followup_stage}>"


class ChatterFollowUpLog(TimestampMixin, db.Model):
   """
   Log storico di tutti i follow-up inviati.
   Traccia ogni invio per analisi e reportistica.
   """
   __tablename__ = "chatter_follow_up_logs"
   
   id = db.Column(db.Integer, primary_key=True)
   
   # Riferimenti
   queue_id = db.Column(
       db.Integer,
       db.ForeignKey("chatter_follow_up_queue.id", ondelete="CASCADE"),
       nullable=False,
       index=True
   )
   
   followup_id = db.Column(
       db.Integer,
       db.ForeignKey("chatter_follow_ups.id", ondelete="SET NULL"),
       index=True
   )
   
   phone_id = db.Column(
       db.Integer,
       db.ForeignKey("whatsapp_phones.id", ondelete="CASCADE"),
       nullable=False,
       index=True
   )
   
   # Dettagli invio
   phone_number = db.Column(db.String(20), nullable=False, index=True)
   chat_id = db.Column(db.String(255), nullable=False, index=True)
   chat_name = db.Column(db.String(255))
   contact_id = db.Column(db.Integer, db.ForeignKey("chatter_contact.id", ondelete="SET NULL"))
   
   # Contenuto inviato
   followup_stage = db.Column(db.Integer, nullable=False)
   message_content = db.Column(db.Text, nullable=False)
   message_preview = db.Column(db.String(500))
   
   # Risultato invio
   sent_successfully = db.Column(db.Boolean, default=True, nullable=False)
   error_message = db.Column(db.String(500))
   periskope_message_id = db.Column(db.String(255))
   periskope_queue_id = db.Column(db.String(255))
   
   # Timing
   scheduled_for = db.Column(db.DateTime, nullable=False)
   sent_at = db.Column(db.DateTime, nullable=False)
   send_delay_seconds = db.Column(db.Integer)  # Ritardo rispetto allo schedulato
   
   # Risposta
   generated_response = db.Column(db.Boolean, default=False, nullable=False)
   response_received_at = db.Column(db.DateTime)
   response_time_minutes = db.Column(db.Integer)  # Tempo di risposta in minuti
   response_message_preview = db.Column(db.String(500))
   
   # Context al momento dell'invio
   contact_tags = db.Column(db.JSON)  # Snapshot dei tag al momento dell'invio
   
   # Relazioni
   queue_entry = relationship("ChatterFollowUpQueue", back_populates="logs")
   follow_up = relationship("ChatterFollowUp", back_populates="logs")
   whatsapp_phone = relationship("WhatsAppPhone")
   contact = relationship("ChatterContact")
   
   # Indici per query performance
   __table_args__ = (
       Index("ix_followup_log_sent_at", "sent_at"),
       Index("ix_followup_log_phone_date", "phone_number", "sent_at"),
       Index("ix_followup_log_response", "generated_response", "response_time_minutes"),
   )
   
   @classmethod
   def create_from_queue(cls, queue: ChatterFollowUpQueue, followup: ChatterFollowUp, 
                        message_content: str, scheduled_time: datetime) -> 'ChatterFollowUpLog':
       """Factory method per creare un log da una queue entry."""
       now = datetime.utcnow()
       delay = int((now - scheduled_time).total_seconds()) if scheduled_time else 0
       
       # Snapshot dei tag del contatto
       contact_tags = queue.contact.tags if queue.contact else []
       
       return cls(
           queue_id=queue.id,
           followup_id=followup.id,
           phone_id=queue.phone_id,
           phone_number=queue.phone_number,
           chat_id=queue.chat_id,
           chat_name=queue.chat_name,
           contact_id=queue.contact_id,
           followup_stage=followup.followup_number,
           message_content=message_content,
           message_preview=message_content[:500] if message_content else "",
           scheduled_for=scheduled_time,
           sent_at=now,
           send_delay_seconds=delay,
           contact_tags=contact_tags,
       )
   
   def mark_response_received(self, response_message: str = None) -> None:
       """Marca che è stata ricevuta una risposta."""
       self.generated_response = True
       self.response_received_at = datetime.utcnow()
       
       if self.sent_at:
           delta = self.response_received_at - self.sent_at
           self.response_time_minutes = int(delta.total_seconds() / 60)
       
       if response_message:
           self.response_message_preview = response_message[:500]
   
   def to_dict(self) -> dict:
       """Serializza per API JSON."""
       return {
           'id': self.id,
           'queue_id': self.queue_id,
           'followup_id': self.followup_id,
           'phone_number': self.phone_number,
           'chat_id': self.chat_id,
           'chat_name': self.chat_name,
           'followup_stage': self.followup_stage,
           'message_preview': self.message_preview,
           'sent_successfully': self.sent_successfully,
           'error_message': self.error_message,
           'scheduled_for': self.scheduled_for.isoformat() if self.scheduled_for else None,
           'sent_at': self.sent_at.isoformat() if self.sent_at else None,
           'send_delay_seconds': self.send_delay_seconds,
           'generated_response': self.generated_response,
           'response_received_at': self.response_received_at.isoformat() if self.response_received_at else None,
           'response_time_minutes': self.response_time_minutes,
           'contact_tags': self.contact_tags,
       }
   
   def __repr__(self) -> str:
       return f"<ChatterFollowUpLog {self.id} stage={self.followup_stage} sent_at={self.sent_at}>"



class ChatterPresetAudio(TimestampMixin, db.Model):
    """
    Audio pre-registrati per ogni numero WhatsApp.
    Permette ai chatter di inviare audio dell'influencer come se fossero registrati al momento.
    """
    __tablename__ = "chatter_preset_audios"
    
    id = db.Column(db.Integer, primary_key=True)
    
    # Relazione con WhatsAppPhone
    phone_id = db.Column(
        db.Integer,
        db.ForeignKey("whatsapp_phones.id", ondelete="CASCADE"),
        nullable=False,
        index=True
    )
    
    # Dettagli audio
    title = db.Column(db.String(100), nullable=False)
    description = db.Column(db.String(500))
    
    # File audio
    file_url = db.Column(db.String(512), nullable=False)  # URL del file su storage
    file_name = db.Column(db.String(255), nullable=False)
    file_size = db.Column(db.Integer)  # Dimensione in bytes
    duration_seconds = db.Column(db.Integer)  # Durata in secondi
    mime_type = db.Column(db.String(100), default="audio/mpeg")
    
    # Categorizzazione opzionale
    category = db.Column(db.String(50), index=True)  # es. "saluti", "info", "promo"
    tags = db.Column(db.JSON, default=list)  # Tag multipli per ricerca
    
    # Shortcut per accesso rapido (es. /audio1, /ciao, etc.)
    shortcut = db.Column(db.String(50), index=True)
    
    # Statistiche utilizzo
    usage_count = db.Column(db.Integer, default=0, nullable=False)
    last_used_at = db.Column(db.DateTime)
    last_used_by_id = db.Column(db.Integer, db.ForeignKey("users.id", ondelete="SET NULL"))
    
    # Stato
    is_active = db.Column(db.Boolean, default=True, nullable=False, index=True)
    
    # Opzioni
    send_as_voice_note = db.Column(db.Boolean, default=True, nullable=False)  # True = PTT, False = Audio file
    position = db.Column(db.Integer, default=0)  # Per ordinamento custom
    
    # Upload info
    uploaded_by_id = db.Column(db.Integer, db.ForeignKey("users.id", ondelete="SET NULL"), nullable=False)
    uploaded_at = db.Column(db.DateTime, default=datetime.utcnow, nullable=False)
    
    # Relazioni
    whatsapp_phone = relationship("WhatsAppPhone", back_populates="preset_audios")
    last_used_by = relationship("User", foreign_keys=[last_used_by_id])
    uploaded_by = relationship("User", foreign_keys=[uploaded_by_id])
    
    # Indici composti per performance
    __table_args__ = (
        # Unicità shortcut per telefono (se definito)
        Index("ix_preset_audio_phone_shortcut", "phone_id", "shortcut", unique=True),
        # Query comuni
        Index("ix_preset_audio_phone_active", "phone_id", "is_active"),
        Index("ix_preset_audio_phone_category", "phone_id", "category", "is_active"),
        # Ordinamento
        Index("ix_preset_audio_position", "phone_id", "position"),
    )
    
    @validates('shortcut')
    def validate_shortcut(self, key, value):
        """Valida che lo shortcut sia nel formato corretto."""
        if value:
            # Rimuovi spazi e converti in lowercase
            value = value.strip().lower()
            # Assicurati che inizi con /
            if not value.startswith('/'):
                value = '/' + value
            # Rimuovi caratteri non validi
            import re
            value = re.sub(r'[^a-z0-9/_-]', '', value)
        return value
    
    def increment_usage(self, user_id: int = None) -> None:
        """Incrementa il contatore di utilizzo."""
        self.usage_count += 1
        self.last_used_at = datetime.utcnow()
        if user_id:
            self.last_used_by_id = user_id
    
    def format_duration(self) -> str:
        """Formatta la durata in formato leggibile (mm:ss)."""
        if not self.duration_seconds:
            return "0:00"
        
        minutes = self.duration_seconds // 60
        seconds = self.duration_seconds % 60
        return f"{minutes}:{seconds:02d}"
    
    def to_dict(self) -> dict:
        """Serializza per API JSON."""
        return {
            'id': self.id,
            'title': self.title,
            'description': self.description,
            'file_url': self.file_url,
            'file_name': self.file_name,
            'file_size': self.file_size,
            'duration': self.duration_seconds,
            'duration_formatted': self.format_duration(),
            'mime_type': self.mime_type,
            'category': self.category,
            'tags': self.tags or [],
            'shortcut': self.shortcut,
            'usage_count': self.usage_count,
            'last_used_at': self.last_used_at.isoformat() if self.last_used_at else None,
            'is_active': self.is_active,
            'send_as_voice_note': self.send_as_voice_note,
            'position': self.position,
            'uploaded_by': self.uploaded_by.full_name if self.uploaded_by else None,
            'uploaded_at': self.uploaded_at.isoformat() if self.uploaded_at else None,
            'created_at': self.created_at.isoformat() if self.created_at else None,
        }
    
    def __repr__(self) -> str:
        return f"<ChatterPresetAudio {self.shortcut or self.title} for phone {self.phone_id}>"



