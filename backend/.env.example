# ===================================================================
# CORPOSOSTENIBILE SUITE - ENVIRONMENT CONFIGURATION
# ===================================================================
# Copia questo file in .env e configura i valori per il tuo ambiente
# NON committare MAI il file .env nel repository!
#
# NOTA PER DOCKER:
# - Se usi Docker Compose, molte variabili hanno default funzionanti
# - Le variabili critiche da configurare sono indicate con [REQUIRED]
# - Le variabili Docker-specific sono indicate con [DOCKER]
# ===================================================================

# ===================================================================
# FLASK CONFIGURATION
# ===================================================================

# Environment: development | testing | production
FLASK_ENV=development

# [REQUIRED] Secret key per sessioni e CSRF (genera una nuova per production!)
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-please-generate-a-secure-key

# Server configuration (per URL generation)
# SERVER_NAME=app.corposostenibile.com
# PREFERRED_URL_SCHEME=https

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# 
# Per installazione locale:
DATABASE_URL=postgresql://corposostenibile:password@localhost:5432/corposostenibile_dev

# [DOCKER] Per Docker Compose, usa 'db' come host:
# DATABASE_URL=postgresql://corposostenibile:password@db:5432/corposostenibile_dev
# Nota: Docker Compose fa l'override automatico, non serve modificare

# Per development con SQLite (non raccomandato per production)
# DATABASE_URL=sqlite:///dev.db

# ===================================================================
# REDIS CONFIGURATION (per Celery e caching)
# ===================================================================
# [DOCKER] Se usi Docker, Redis è già configurato automaticamente

# Redis per Celery broker
CELERY_BROKER_URL=redis://localhost:6379/0

# Redis per Celery results
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Redis per caching generale
CACHE_REDIS_URL=redis://localhost:6379/2

# Redis per WebSocket (Periskope)
WEBSOCKET_QUEUE=redis://localhost:6379/3

# Redis per scheduler
SCHEDULER_REDIS_DB=4

# ===================================================================
# CELERY & TASK SCHEDULING
# ===================================================================

# Abilita/disabilita Celery (1=on, 0=off)
USE_CELERY=1

# Abilita/disabilita APScheduler (1=on, 0=off)
USE_APSCHEDULER=0

# Scheduler timezone
SCHEDULER_TIMEZONE=Europe/Rome

# Scheduler thread pool
SCHEDULER_THREAD_POOL_SIZE=10
SCHEDULER_PROCESS_POOL_SIZE=2

# Misfire grace time (secondi)
SCHEDULER_MISFIRE_GRACE_TIME=300

# ===================================================================
# EMAIL CONFIGURATION
# ===================================================================

# [REQUIRED per invio email] SMTP server settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
# Per Gmail, usa App Password: https://support.google.com/accounts/answer/185833
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@corposostenibile.com

# [DOCKER] Per test email in development, usa Mailhog:
# MAIL_SERVER=mailhog
# MAIL_PORT=1025
# MAIL_USE_TLS=0

# Abilita invio email per ticket (1=on, 0=off)
TICKET_EMAIL_ENABLED=0

# ===================================================================
# GOOGLE OAUTH2 & APIS - DEPRECATO (NON PIÙ UTILIZZATO)
# ===================================================================

# Google OAuth2 non è più utilizzato in questa versione
# Le seguenti variabili sono mantenute per compatibilità ma non sono richieste
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URL=http://localhost:5000/auth/google/callback
# GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/calendar.events

# ===================================================================
# GOOGLE AI / GEMINI (GenAI)
# ===================================================================

# [OPTIONAL] API key server-side per chiamare Gemini (usata da assignments AI, SOP chatbot, SuiteMind, Recruiting AI, ...)
# IMPORTANT: non committare MAI questa chiave. Tenerla solo in .env (locale) o in variabili ambiente del deploy.
GOOGLE_API_KEY=

# [OPTIONAL] Modello usato per estrazione criteri lead (AIMatchingService)
# Esempi: gemini-2.0-flash, gemini-2.0-flash-lite
GEMINI_LEAD_CRITERIA_MODEL=gemini-flash-latest

# ===================================================================
# FILE UPLOAD CONFIGURATION
# ===================================================================

# Directory per upload files (path assoluto o relativo)
# Per Docker, usa path relativo che verrà montato come volume
UPLOAD_FOLDER=./uploads

# Max upload size in bytes (default 16MB)
MAX_UPLOAD_SIZE=16777216

# Per production con S3
# USE_S3=1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=corposostenibile-uploads
# AWS_S3_REGION=eu-west-1

# CDN URL (opzionale)
# CDN_URL=https://cdn.corposostenibile.com

# ===================================================================
# PERISKOPE INTEGRATION (WhatsApp/Chat)
# ===================================================================

# Periskope API credentials
PERISKOPE_API_KEY=your-periskope-api-key
PERISKOPE_API_URL=https://api.periskope.app/v1

# Webhook configuration
PERISKOPE_WEBHOOK_SECRET=your-webhook-secret
PERISKOPE_WEBHOOK_URL=https://app.corposostenibile.com/webhook/periskope

# WebSocket configuration
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=10

# Rate limiting
PERISKOPE_RATE_LIMIT=60
PERISKOPE_RATE_LIMIT_WINDOW=60

# Retry configuration
PERISKOPE_MAX_RETRIES=3
PERISKOPE_RETRY_DELAY=2

# Follow-up quiet hours (no messages sent between midnight and start hour)
PERISKOPE_FOLLOWUP_START_HOUR=7    # Start sending at 7:00 AM
PERISKOPE_FOLLOWUP_END_HOUR=24     # Stop sending at midnight (24:00)

# ===================================================================
# TRUSTPILOT INTEGRATION
# ===================================================================

TRUSTPILOT_ENABLED=0
TRUSTPILOT_API_KEY=
TRUSTPILOT_API_SECRET=
TRUSTPILOT_BUSINESS_UNIT_ID=
TRUSTPILOT_BUSINESS_USER_ID=
TRUSTPILOT_REDIRECT_URI=
TRUSTPILOT_WEBHOOK_USERNAME=
TRUSTPILOT_WEBHOOK_PASSWORD=
TRUSTPILOT_EMAIL_TEMPLATE_ID=
TRUSTPILOT_SENDER_NAME=
TRUSTPILOT_SENDER_EMAIL=
TRUSTPILOT_REPLY_TO=
TRUSTPILOT_LOCALE_DEFAULT=it-IT
TRUSTPILOT_TIMEOUT_SECONDS=20

# ===================================================================
# NUTRITION MODULE CONFIGURATION
# ===================================================================

# External food database API (optional)
# FOOD_API_URL=https://api.openfoodfacts.org/api/v2
# FOOD_API_KEY=your-api-key

# Food search cache TTL (seconds)
FOOD_SEARCH_CACHE_TTL=3600

# Limits
MAX_MEAL_PLAN_DAYS=90
MAX_FOODS_PER_MEAL=20

# ===================================================================
# ACCOUNTING MODULE CONFIGURATION
# ===================================================================

# First and last month for accounting reports (YYYY-MM format)
ACCOUNTING_FIRST_MONTH=2024-01
ACCOUNTING_LAST_MONTH=2035-12

# ===================================================================
# DEVELOPMENT SPECIFIC
# ===================================================================

# Use mock data for food database in development
USE_MOCK_FOOD_DATA=1

# Debug toolbar (only in development!)
# DEBUG_TB_ENABLED=1
# DEBUG_TB_INTERCEPT_REDIRECTS=0

# ===================================================================
# PRODUCTION SPECIFIC
# ===================================================================

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-key@sentry.io/project-id

# New Relic monitoring (optional)
# NEW_RELIC_LICENSE_KEY=your-license-key
# NEW_RELIC_APP_NAME=Corposostenibile Suite

# ===================================================================
# TESTING SPECIFIC
# ===================================================================

# Test upload folder
TEST_UPLOAD_FOLDER=/tmp/corposostenibile_test_uploads

# ===================================================================
# LOGGING
# ===================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional, defaults to logs/app.log)
# LOG_FILE=/var/log/corposostenibile/app.log

# ===================================================================
# SECURITY
# ===================================================================

# Session cookie settings
SESSION_COOKIE_SECURE=0  # Set to 1 in production with HTTPS
SESSION_COOKIE_HTTPONLY=1
SESSION_COOKIE_SAMESITE=Lax

# Password policy
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=1
REQUIRE_NUMBERS=1
REQUIRE_SPECIAL_CHARS=0

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300  # seconds

# ===================================================================
# FEATURE FLAGS
# ===================================================================

# Enable/disable specific features
FEATURE_NUTRITION_MODULE=1
FEATURE_PERISKOPE_CHAT=1
FEATURE_GOOGLE_CALENDAR=1
FEATURE_EMAIL_NOTIFICATIONS=1
FEATURE_TWO_FACTOR_AUTH=0

# ===================================================================
# QUICK START - VARIABILI MINIME PER DOCKER
# ===================================================================
# Per avviare rapidamente con Docker, configura solo queste:
#
# 1. SECRET_KEY=<genera-con-comando-sopra>
# 2. GOOGLE_CLIENT_ID=<dal-tuo-progetto-google>
# 3. GOOGLE_CLIENT_SECRET=<dal-tuo-progetto-google>
# 4. MAIL_USERNAME=<tua-email>
# 5. MAIL_PASSWORD=<app-password>
#
# Tutto il resto ha default funzionanti per Docker!
# ===================================================================

# ===================================================================
# MICROSOFT TEAMS BOT (Team Tickets)
# ===================================================================
# Registra il bot in Azure Portal → Bot Services
# Messaging endpoint: https://clinica.corposostenibile.com/api/teams-bot/messages

# [REQUIRED per Teams bot] App ID dal registration Azure
TEAMS_BOT_APP_ID=
# [REQUIRED per Teams bot] App Password dal registration Azure
TEAMS_BOT_APP_PASSWORD=
# [OPTIONAL] Tenant ID per single-tenant apps
TEAMS_BOT_TENANT_ID=

# ===================================================================
# CLICKUP INTEGRATION (IT Support Tickets - blueprint "it_support")
# ===================================================================
# Workspace ClickUp dove vengono inoltrati i ticket IT aperti dagli utenti.
# Il team IT gestisce triage/risoluzione direttamente su ClickUp.
# Setup iniziale: creare Workspace, Space "Suite Clinica - Ticket", List "Ticket"
# con 14 custom fields + 7 statuses. Vedi README del blueprint.
# ===================================================================

# Feature flag (1=on, 0=off). Se off, il blueprint resta registrato ma i task
# ClickUp non vengono creati (utile per dev/staging senza workspace dedicato).
CLICKUP_INTEGRATION_ENABLED=0

# [REQUIRED se CLICKUP_INTEGRATION_ENABLED=1]
# Personal API Token (consigliato: service account dedicato "it-bot@...")
# Genera da: ClickUp → Avatar → Settings → Apps → API Token
CLICKUP_API_TOKEN=

# [REQUIRED] HMAC secret per verifica payload webhook inbound
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
CLICKUP_WEBHOOK_SECRET=

# Workspace / Space / List IDs (recuperabili via GET /api/v2/team, ecc.)
CLICKUP_WORKSPACE_ID=
CLICKUP_SPACE_ID=
CLICKUP_LIST_ID=

# Webhook endpoint pubblico. Registrato auto-magicamente al primo avvio.
# Production:  https://<dominio-prod>/webhooks/clickup
# Development: esporre via ngrok
CLICKUP_WEBHOOK_URL=http://localhost:5000/webhooks/clickup

# ─── Custom Fields (UUIDs, da GET /api/v2/list/<id>/field) ─────────
CLICKUP_FIELD_TIPO=
CLICKUP_FIELD_MODULO=
CLICKUP_FIELD_CRITICITA=
CLICKUP_FIELD_TICKET_ID=
CLICKUP_FIELD_EMAIL_UTENTE=
CLICKUP_FIELD_NOME_UTENTE=
CLICKUP_FIELD_RUOLO=
CLICKUP_FIELD_SPECIALITA=
CLICKUP_FIELD_CLIENTE_COINVOLTO=
CLICKUP_FIELD_BROWSER=
CLICKUP_FIELD_OS=
CLICKUP_FIELD_VERSIONE_APP=
CLICKUP_FIELD_COMMIT_SHA=
CLICKUP_FIELD_LINK_REGISTRAZIONE=
CLICKUP_FIELD_ALLEGATO=

# ─── Dropdown Option UUIDs — Tipo ──────────────────────────────────
CLICKUP_OPT_TIPO_BUG=
CLICKUP_OPT_TIPO_DATO_ERRATO=
CLICKUP_OPT_TIPO_ACCESSO=
CLICKUP_OPT_TIPO_LENTEZZA=

# ─── Dropdown Option UUIDs — Modulo ────────────────────────────────
CLICKUP_OPT_MODULO_ASSEGNAZIONI=
CLICKUP_OPT_MODULO_CALENDARIO=
CLICKUP_OPT_MODULO_CHECK=
CLICKUP_OPT_MODULO_CLIENTI=
CLICKUP_OPT_MODULO_DASHBOARD=
CLICKUP_OPT_MODULO_FORMAZIONE=
CLICKUP_OPT_MODULO_GENERICO=
CLICKUP_OPT_MODULO_PROFILO=
CLICKUP_OPT_MODULO_QUALITY=
CLICKUP_OPT_MODULO_SUPPORTO=
CLICKUP_OPT_MODULO_TASK=
CLICKUP_OPT_MODULO_TEAM=

# ─── Dropdown Option UUIDs — Criticità ─────────────────────────────
CLICKUP_OPT_CRITICITA_BLOCCANTE=
CLICKUP_OPT_CRITICITA_NON_BLOCCANTE=

# ─── Status IDs (Space-level) ──────────────────────────────────────
CLICKUP_STATUS_NUOVO=
CLICKUP_STATUS_IN_TRIAGE=
CLICKUP_STATUS_IN_LAVORAZIONE=
CLICKUP_STATUS_IN_ATTESA_UTENTE=
CLICKUP_STATUS_DA_TESTARE=
CLICKUP_STATUS_RISOLTO=
CLICKUP_STATUS_NON_VALIDO=

# ===================================================================
# CLICKUP INTEGRATION - GHL SUPPORT (blueprint "ghl_support")
# ===================================================================
# Space ClickUp dedicato ai ticket aperti dai sales dall'interno di
# GoHighLevel via Custom Menu Link. Usa lo stesso CLICKUP_API_TOKEN e
# CLICKUP_WORKSPACE_ID del IT Support.
# Space: "Go High Level - Ticket" (ID 90127111740)
# ===================================================================

CLICKUP_GHL_INTEGRATION_ENABLED=0

# Space / List IDs del nuovo space GHL
CLICKUP_GHL_SPACE_ID=
CLICKUP_GHL_LIST_ID=

# Webhook endpoint pubblico (stesso tunnel Cloudflare del IT Support)
CLICKUP_GHL_WEBHOOK_URL=http://localhost:5000/webhooks/clickup-ghl

# HMAC secret — popolato dopo `flask ghl-support register-webhook`
CLICKUP_GHL_WEBHOOK_SECRET=

# ─── Custom Fields UUIDs (6 field, solo metadati) ──────────────────
CLICKUP_GHL_FIELD_TICKET_ID=
CLICKUP_GHL_FIELD_EMAIL_UTENTE=
CLICKUP_GHL_FIELD_NOME_UTENTE=
CLICKUP_GHL_FIELD_USER_ID_GHL=
CLICKUP_GHL_FIELD_BROWSER=
CLICKUP_GHL_FIELD_OS=

# ─── Status IDs (space-level) ──────────────────────────────────────
CLICKUP_GHL_STATUS_NUOVO=
CLICKUP_GHL_STATUS_IN_ANALISI=
CLICKUP_GHL_STATUS_IN_LAVORAZIONE=
CLICKUP_GHL_STATUS_IN_ATTESA_HIGHLEVEL=
CLICKUP_GHL_STATUS_IN_ATTESA_UTENTE=
CLICKUP_GHL_STATUS_RISOLTO=
CLICKUP_GHL_STATUS_NON_VALIDO=

# ===================================================================
# GHL SUPPORT SSO (Opzione A - Custom Menu Link)
# ===================================================================
# Chiave HS256 per firmare i JWT di sessione GHL. Se vuota usa SECRET_KEY.
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
GHL_SSO_SIGNING_KEY=

# ===================================================================
# NOTES
# ===================================================================
# 1. In production, usa sempre HTTPS e configura SERVER_NAME
# 2. Genera sempre una SECRET_KEY sicura per production
# 3. Non usare SQLite in production
# 4. Configura backup automatici del database
# 5. Monitora logs e metriche in production
# 6. Usa un reverse proxy (NGINX) in production
# ===================================================================