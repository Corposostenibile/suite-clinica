// Create metric toggle buttons
function createMetricToggles() {
    const togglesContainer = document.getElementById('metric-toggles');
    if (!togglesContainer || !metricsData) return;
    
    let togglesHtml = '';
    
    // Create a toggle for each metric (except weight and progress)
    const metricsToShow = ['digestion', 'energy', 'strength', 'sleep', 'mood', 'motivation', 'hunger', 'progress'];
    
    metricsToShow.forEach((key) => {
        const metric = metricsData.metrics[key];
        if (metric) {
            // Create toggle with the metric's color
            togglesHtml += `
                <span class="metric-toggle active" 
                      data-metric="${key}"
                      style="background-color: ${metric.color}20; 
                             border-color: ${metric.color}; 
                             color: ${metric.color};">
                    ${metric.label}
                </span>
            `;
        }
    });
    
    togglesContainer.innerHTML = togglesHtml;
    
    // Add click handlers to toggles
    document.querySelectorAll('.metric-toggle').forEach(toggle => {
        toggle.addEventListener('click', function() {
            const metricKey = this.getAttribute('data-metric');
            toggleMetricVisibility(metricKey, this);
        });
    });
}

// Toggle metric visibility in the chart
function toggleMetricVisibility(metricKey, toggleElement) {
    if (!physicalChart) return;
    
    // Find the dataset index for this metric
    const datasetIndex = physicalChart.data.datasets.findIndex(ds => 
        ds.label === metricsData.metrics[metricKey].label
    );
    
    if (datasetIndex === -1) return;
    
    // Toggle visibility
    const isVisible = physicalChart.isDatasetVisible(datasetIndex);
    
    if (isVisible) {
        physicalChart.hide(datasetIndex);
        toggleElement.classList.remove('active');
        toggleElement.classList.add('inactive');
    } else {
        physicalChart.show(datasetIndex);
        toggleElement.classList.remove('inactive');
        toggleElement.classList.add('active');
    }
}

