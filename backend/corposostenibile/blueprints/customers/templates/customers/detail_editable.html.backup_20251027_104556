                                                </tr>
                                                {% endif %}
                                                {% if response.training_program_adherence %}
                                                <tr>
                                                  <td class="text-muted">💪 Programma Allenamento</td>
                                                  <td>{{ response.training_program_adherence }}</td>
                                                </tr>
                                                {% endif %}
