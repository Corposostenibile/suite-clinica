                                                                                            <small class="text-muted d-block mb-1">Nutrizionista</small>
                                                                                            <strong class="text-primary fs-5">{{ response.nutritionist_rating }}/10</strong>
                                                                                        </div>
                                                                                    </div>
                                                                                    {% endif %}
                                                                                    {% if response.psychologist_rating %}
