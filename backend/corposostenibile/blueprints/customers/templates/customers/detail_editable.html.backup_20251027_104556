                                            {% if can_see_nutrition_ratings and response.nutritionist_feedback %}
                                            <div class="col-md-4">
                                              <div class="card h-100">
                                                <div class="card-body">
                                                  <h6 class="card-subtitle mb-2 text-muted">🥗 Nutrizionista</h6>
                                                  <p class="card-text small">{{ response.nutritionist_feedback }}</p>
                                                </div>
                                              </div>
                                            </div>
                                            {% endif %}
                                            {% if can_see_psychology_ratings and response.psychologist_feedback %}
                                            <div class="col-md-4">
                                              <div class="card h-100">
                                                <div class="card-body">
                                                  <h6 class="card-subtitle mb-2 text-muted">🧠 Psicologo</h6>
                                                  <p class="card-text small">{{ response.psychologist_feedback }}</p>
                                                </div>
                                              </div>
                                            </div>
                                            {% endif %}
                                            {% if can_see_coach_ratings and response.coach_feedback %}
                                            <div class="col-md-4">
                                              <div class="card h-100">
                                                <div class="card-body">
                                                  <h6 class="card-subtitle mb-2 text-muted">🏋️ Coach</h6>
                                                  <p class="card-text small">{{ response.coach_feedback }}</p>
                                                </div>
                                              </div>
                                            </div>
                                            {% endif %}
                                          </div>
                                        </div>
                                        {% endif %}

                                        <!-- SEZIONE INFO AGGIUNTIVE (se presenti) -->
                                        {% if response.live_session_topics or response.extra_comments or response.referral %}
                                        <div class="mb-4">
                                          <h6 class="text-primary fw-bold mb-4">📝 INFORMAZIONI AGGIUNTIVE</h6>
                                          <div class="list-group list-group-flush">
                                            {% if response.live_session_topics %}
                                            <div class="list-group-item px-0">
                                              <small class="text-muted d-block">🎯 Argomenti Sessioni Live</small>
                                              <span>{{ response.live_session_topics }}</span>
                                            </div>
                                            {% endif %}
                                            {% if response.extra_comments %}
                                            <div class="list-group-item px-0">
                                              <small class="text-muted d-block">💬 Commenti Aggiuntivi</small>
                                              <span>{{ response.extra_comments }}</span>
                                            </div>
                                            {% endif %}
                                            {% if response.referral %}
                                            <div class="list-group-item px-0">
                                              <small class="text-muted d-block">🤝 Referral</small>
                                              <span>{{ response.referral }}</span>
                                            </div>
                                            {% endif %}
                                          </div>
                                        </div>
                                        {% endif %}
                                      </div>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            {% endfor %}
                          </div>
                        </div>
                      {% else %}
                        <div class="alert alert-light border text-center py-4">
                          <i class="bi bi-clipboard-x" style="font-size: 3rem; color: #dee2e6;"></i>
                          <p class="text-muted mt-2 mb-0">Nessun feedback ricevuto</p>
                        </div>
                      {% endif %}
                    </div>
                    {% endif %}

                    <!-- TAB CHECK 2.0 (NUOVA GESTIONE - CLIENT_CHECKS) -->
                    {% if current_user.is_admin %}
                    <div class="tab-pane fade" id="pills-check2" role="tabpanel">
                        <!-- Sub-tabs per Check Sales, Check Iniziale e Settimanale -->
                        <ul class="nav nav-pills mb-4" id="checkTabs2" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="check2-sales-tab" data-bs-toggle="pill"
