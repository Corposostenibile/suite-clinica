                                                                                            <small class="text-muted d-block mb-1">Coach</small>
                                                                                            <strong class="text-primary fs-5">{{ response.coach_rating }}/10</strong>
                                                                                        </div>
                                                                                    </div>
                                                                                    {% endif %}
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
