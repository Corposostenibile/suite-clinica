/**
 * Renderizza il dettaglio del Weekly Check
 */
function renderWeeklyCheckDetail(check) {
    let html = `
        <!-- Header -->
        <div class="mb-4 p-3 bg-light rounded">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="mb-2"><strong>Cliente:</strong> ${check.cliente_nome || 'N/D'}</h6>
                    <p class="mb-1"><strong>Data Compilazione:</strong> ${check.submit_date || 'N/D'}</p>
                    <p class="mb-0"><strong>Completamento:</strong> ${check.completion_percentage}%</p>
                </div>
                <div class="col-md-6 text-end">
                    <h6 class="mb-2"><strong>Peso:</strong> ${check.weight ? check.weight + ' Kg' : 'Non specificato'}</h6>
                    <p class="mb-0"><strong>Progresso:</strong> ${check.progress_rating ? check.progress_rating + '/10' : 'Non valutato'}</p>
                </div>
            </div>
        </div>
    `;

    // Foto Fisico
    if (check.photo_front || check.photo_side || check.photo_back) {
        html += `
            <h6 class="section-header mt-4 mb-3"><i class="ri-camera-line me-2"></i>Foto Fisico</h6>
            <div class="row g-3 mb-4">
                ${check.photo_front ? `<div class="col-md-4"><img src="/${check.photo_front}" class="img-fluid rounded" alt="Foto frontale"></div>` : ''}
                ${check.photo_side ? `<div class="col-md-4"><img src="/${check.photo_side}" class="img-fluid rounded" alt="Foto laterale"></div>` : ''}
                ${check.photo_back ? `<div class="col-md-4"><img src="/${check.photo_back}" class="img-fluid rounded" alt="Foto posteriore"></div>` : ''}
            </div>
        `;
    }

    // Riflessioni
    html += `<h6 class="section-header mt-4 mb-3"><i class="ri-lightbulb-line me-2"></i>Riflessioni Settimanali</h6>`;
    html += renderTextField('Cosa ha funzionato', check.what_worked);
    html += renderTextField('Cosa NON ha funzionato', check.what_didnt_work);
    html += renderTextField('Cosa hai imparato', check.what_learned);
    html += renderTextField('Focus prossima settimana', check.what_focus_next);
    html += renderTextField('Infortuni/Note', check.injuries_notes);

    // Valutazioni Benessere
    html += `<h6 class="section-header mt-4 mb-3"><i class="ri-heart-pulse-line me-2"></i>Valutazioni Benessere (0-10)</h6>`;
    html += `<div class="row g-3 mb-3">`;
    html += renderRatingBadge('Digestione', check.digestion_rating);
    html += renderRatingBadge('Energia', check.energy_rating);
    html += renderRatingBadge('Forza', check.strength_rating);
    html += renderRatingBadge('Fame', check.hunger_rating);
    html += renderRatingBadge('Sonno', check.sleep_rating);
    html += renderRatingBadge('Umore', check.mood_rating);
    html += renderRatingBadge('Motivazione', check.motivation_rating);
    html += `</div>`;

    // Valutazioni Professionisti
    html += `<h6 class="section-header mt-4 mb-3"><i class="ri-team-line me-2"></i>Valutazioni Professionisti (1-10)</h6>`;
    if (check.nutritionist_rating) {
        html += renderProfessionalRating('Nutrizionista', check.nutritionist_rating, check.nutritionist_feedback);
    }
    if (check.psychologist_rating) {
        html += renderProfessionalRating('Psicologa', check.psychologist_rating, check.psychologist_feedback);
    }
    if (check.coach_rating) {
        html += renderProfessionalRating('Coach', check.coach_rating, check.coach_feedback);
    }

    // Aderenza Programmi
    html += `<h6 class="section-header mt-4 mb-3"><i class="ri-calendar-check-line me-2"></i>Aderenza ai Programmi</h6>`;
    html += renderTextField('Programma Alimentare', check.nutrition_program_adherence);
    html += renderTextField('Programma Sportivo', check.training_program_adherence);
    html += renderTextField('Modifiche Esercizi', check.exercise_modifications);
    html += renderTextField('Passi Giornalieri', check.daily_steps);

    // Extra
    if (check.referral) {
        html += `<h6 class="section-header mt-4 mb-3"><i class="ri-user-add-line me-2"></i>Referral</h6>`;
        html += renderTextField('Persona da Contattare', check.referral);
    }

    if (check.extra_comments) {
        html += `<h6 class="section-header mt-4 mb-3"><i class="ri-chat-3-line me-2"></i>Commenti Extra</h6>`;
        html += renderTextField('Commenti', check.extra_comments);
    }

    return html;
}

function renderTextField(label, value) {
    if (!value) return '';
    return `
        <div class="mb-3">
            <strong>${label}:</strong>
            <p class="mb-0 text-muted">${value}</p>
        </div>
    `;
}

function renderRatingBadge(label, value) {
    if (value === null || value === undefined) return '';
    const color = value >= 7 ? 'success' : value >= 4 ? 'warning' : 'danger';
    return `
        <div class="col-md-3">
            <div class="card">
                <div class="card-body text-center p-2">
                    <small class="text-muted d-block mb-1">${label}</small>
                    <h4 class="mb-0"><span class="badge bg-${color}">${value}/10</span></h4>
                </div>
            </div>
        </div>
    `;
}

function renderProfessionalRating(name, rating, feedback) {
    const color = rating >= 8 ? 'success' : rating >= 5 ? 'warning' : 'danger';
    return `
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="mb-2">${name}: <span class="badge bg-${color}">${rating}/10</span></h6>
                ${feedback ? `<p class="mb-0 text-muted">${feedback}</p>` : '<p class="mb-0 text-muted">Nessun feedback fornito</p>'}
            </div>
        </div>
    `;
}
</script>

