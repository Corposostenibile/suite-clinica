                                                            {% else %}
                                                                <iconify-icon icon="fluent-emoji-flat:green-salad" class="rating-icon"></iconify-icon>
                                                            {% endif %}
                                                            {{ rating_badge(response.nutritionist_rating, false) }}
                                                        </div>
                                                        {% endif %}

                                                        {% if can_see_psychology_ratings and response.psychologist_rating %}
                                                        {% set psicologo = cliente.psicologi_multipli[0] if cliente.psicologi_multipli else cliente.psicologa_user %}
                                                        <div class="rating-item">
                                                            {% if psicologo and psicologo.avatar_path %}
                                                                <img src="{{ url_for('team.serve_avatar', user_id=psicologo.id, filename=psicologo.avatar_path) }}"
                                                                     alt="{{ psicologo.full_name }}" class="rating-icon rounded-circle">
                                                            {% else %}
                                                                <iconify-icon icon="material-icon-theme:brainfuck" class="rating-icon"></iconify-icon>
                                                            {% endif %}
                                                            {{ rating_badge(response.psychologist_rating, false) }}
                                                        </div>
                                                        {% endif %}

                                                        {% if can_see_coach_ratings and response.coach_rating %}
