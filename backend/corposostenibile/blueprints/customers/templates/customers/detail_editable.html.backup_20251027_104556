{% block extra_js %}
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Store CSRF token from Flask template
const CSRF_TOKEN = "{{ csrf_token() }}";

// Form management
function resetForm(formId) {
    document.getElementById(formId).reset();
}

// Professional field management
function addProfessionalField(type) {
    const container = document.getElementById(type + '-container');
    const existingFields = container.querySelectorAll('.professional-field');
    
    // Get the options from the first select
    const firstSelect = existingFields[0].querySelector('select');
    const optionsHtml = firstSelect.innerHTML;
    
    // Create new field
    const newField = document.createElement('div');
    newField.className = 'professional-field mb-2';
    newField.innerHTML = `
        <div class="input-group">
            <select class="form-control radius-8 form-select" name="${type}_ids[]">
                ${optionsHtml}
            </select>
            <button type="button" class="btn btn-danger" onclick="removeProfessionalField(this)">
                <i class="ri-delete-bin-line"></i>
            </button>
        </div>
    `;
    
    container.appendChild(newField);
}

function removeProfessionalField(button) {
    const field = button.closest('.professional-field');
    const container = field.parentElement;
    
    // Keep at least one field
    if (container.querySelectorAll('.professional-field').length > 1) {
        field.remove();
    } else {
        // If it's the last field, just clear the selection
        field.querySelector('select').value = '';
    }
}

// Calcola automaticamente la Data Rinnovo
function calcolaDataRinnovo() {
    const dataInizioInput = document.getElementById('data_inizio_abbonamento');
    const durataInput = document.getElementById('durata_programma_giorni');
    const dataRinnovoInput = document.getElementById('data_rinnovo');
    const infoLabel = document.getElementById('data_rinnovo_info');
    
    if (dataInizioInput && durataInput && dataRinnovoInput) {
        const dataInizio = dataInizioInput.value;
        const durata = parseInt(durataInput.value);
        
        if (dataInizio && durata && durata > 0) {
            // Calcola la nuova data di rinnovo
            const startDate = new Date(dataInizio);
            startDate.setDate(startDate.getDate() + durata);
            
            // Formatta la data nel formato YYYY-MM-DD per l'input date
            const year = startDate.getFullYear();
            const month = String(startDate.getMonth() + 1).padStart(2, '0');
            const day = String(startDate.getDate()).padStart(2, '0');
            const formattedDate = `${year}-${month}-${day}`;
            
            // Aggiorna il campo data_rinnovo
            dataRinnovoInput.value = formattedDate;
            dataRinnovoInput.readOnly = true;
            dataRinnovoInput.style.backgroundColor = '#f0f0f0';
            
            // Mostra che è calcolata automaticamente
            if (infoLabel) {
                infoLabel.style.display = 'inline';
                infoLabel.innerHTML = '(calcolata automaticamente)';
            }
            
            console.log(`Data Rinnovo calcolata: ${dataInizio} + ${durata} giorni = ${formattedDate}`);
        } else {
            // Se mancano i dati, permetti modifica manuale
            dataRinnovoInput.readOnly = false;
            dataRinnovoInput.style.backgroundColor = '';
            
            if (infoLabel) {
                infoLabel.style.display = 'inline';
                infoLabel.innerHTML = '(inserimento manuale)';
            }
        }
    }
}

// Calcola al caricamento della pagina se ci sono già i dati
document.addEventListener('DOMContentLoaded', function() {
    calcolaDataRinnovo();
});

// Get CSRF token
function getCSRFToken() {
    return CSRF_TOKEN;
}

// Track original values for each form
const originalValues = {};
document.querySelectorAll('form[data-cliente-id]').forEach(form => {
    const formId = form.id;
    originalValues[formId] = {};
    
    // Store original values
    form.querySelectorAll('input, select, textarea').forEach(field => {
        if (field.type === 'checkbox') {
            originalValues[formId][field.name] = field.checked;
        } else {
            originalValues[formId][field.name] = field.value;
        }
    });
});

// AJAX form submission with change tracking
document.querySelectorAll('form[data-cliente-id]').forEach(form => {
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        const clienteId = form.dataset.clienteId;
        const formId = form.id;
        const data = {};
        const changes = {};
        const submitBtn = form.querySelector('button[type="submit"]');
        
        // Disable submit button
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Salvataggio...';
        }
        
        // Handle professional arrays
        const professionalArrays = {
            'nutrizionisti_ids[]': 'nutrizionisti_ids',
            'coaches_ids[]': 'coaches_ids',
            'psicologi_ids[]': 'psicologi_ids',
            'consulenti_ids[]': 'consulenti_ids'
        };
        
        // Collect array values - SOLO se ci sono select nel form corrente
        const arrayValues = {};
        for (let [arrayName, targetName] of Object.entries(professionalArrays)) {
            const selects = form.querySelectorAll(`select[name="${arrayName}"]`);
            
            // IMPORTANTE: invia l'array SOLO se ci sono select nel form corrente
            // Se non ci sono select, non inviare nulla per preservare i valori esistenti
            if (selects.length > 0) {
                arrayValues[targetName] = [];
                selects.forEach(select => {
                    if (select.value) {
                        arrayValues[targetName].push(select.value);
                    }
                });
                // Invia l'array anche se vuoto (per permettere la rimozione esplicita)
                // ma SOLO se ci sono effettivamente dei select nel form
            }
            // Se selects.length === 0, non aggiungiamo nulla a arrayValues
            // quindi il backend preserverà le relazioni esistenti
        }
        
        // Convert FormData to JSON and track changes
        for (let [key, value] of formData.entries()) {
            // Skip array fields (we handle them separately)
            if (key.endsWith('[]')) {
                continue;
            }
            
            // Handle checkboxes specially
            if (form.elements[key] && form.elements[key].type === 'checkbox') {
                data[key] = form.elements[key].checked;
                if (originalValues[formId][key] !== form.elements[key].checked) {
                    changes[key] = {
                        old: originalValues[formId][key],
                        new: form.elements[key].checked
                    };
                }
            } else {
                data[key] = value || null;
                if (originalValues[formId][key] !== value) {
                    changes[key] = {
                        old: originalValues[formId][key],
                        new: value
                    };
                }
            }
        }
        
        // Add array values to data - SOLO se esistono nel form corrente
        // Se non ci sono select per quel tipo nel form, NON inviamo nulla
        // così il backend preserverà le relazioni esistenti
        for (let key in arrayValues) {
            // Aggiungi solo se abbiamo effettivamente raccolto valori per questo tipo
            data[key] = arrayValues[key];
        }
        
        // Add unchecked checkboxes (they don't appear in FormData)
        form.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
            if (!data.hasOwnProperty(checkbox.name)) {
                data[checkbox.name] = checkbox.checked;
                if (originalValues[formId][checkbox.name] !== checkbox.checked) {
                    changes[checkbox.name] = {
                        old: originalValues[formId][checkbox.name],
                        new: checkbox.checked
                    };
                }
            }
        });
        
        console.log('Changes detected:', changes);  // Debug log
        console.log('Data being sent:', data);  // Debug log per vedere tutti i dati inviati
        console.log('Professional arrays:', {
            nutrizionisti: data.nutrizionisti_ids || 'not present',
            coaches: data.coaches_ids || 'not present',
            psicologi: data.psicologi_ids || 'not present',
            consulenti: data.consulenti_ids || 'not present'
        });  // Debug log specifico per gli array dei professionisti
        
        try {
            const response = await fetch(`/customers/${clienteId}/update`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRFToken': getCSRFToken(),
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(data)
            });
            
            const result = await response.json();
            
            if (response.ok) {
                // Update original values after successful save
                Object.keys(data).forEach(key => {
                    originalValues[formId][key] = data[key];
                });
                
                // Show success message with Bootstrap toast or alert
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-success alert-dismissible fade show position-fixed top-0 end-0 m-3';
                alertDiv.style.zIndex = '9999';
                alertDiv.innerHTML = `
                    ${result.message || 'Dati salvati con successo!'}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.body.appendChild(alertDiv);
                
                // Refresh la pagina dopo 1 secondo per vedere subito le modifiche
                setTimeout(() => {
                    window.location.reload();
                }, 1000);
            } else {
                // Show error message
                const errorMsg = result.error || 'Errore nel salvataggio dei dati';
                alert('Errore: ' + errorMsg);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Errore di connessione: ' + error.message);
        } finally {
            // Re-enable submit button
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Salva';
            }
        }
    });
});

