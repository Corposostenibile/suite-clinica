// Funzione helper per formattare il valore del campo
function formatFieldValue(field) {
    const value = field.value;

    if (!value && value !== 0 && value !== false) {
        return '<em class="text-muted">Nessuna risposta</em>';
    }

    switch (field.field_type) {
        case 'scale':
            const max = field.options?.max || 10;
            const min = field.options?.min || 1;
            const percentage = ((value - min) / (max - min)) * 100;
            return `
                <div class="d-flex align-items-center gap-3">
                    <strong class="text-primary" style="min-width: 2rem;">${value}</strong>
                    <div class="flex-grow-1 bg-secondary bg-opacity-25 rounded" style="height: 8px;">
                        <div class="bg-primary rounded" style="height: 100%; width: ${percentage}%;"></div>
                    </div>
                    <small class="text-muted">/ ${max}</small>
                </div>
            `;

        case 'checkbox':
            if (Array.isArray(value)) {
                return value.map(item =>
                    `<span class="badge bg-success me-1 mb-1">${item}</span>`
                ).join('');
            }
            return `<span class="badge bg-success">${value}</span>`;

        case 'textarea':
            return `<div style="white-space: pre-wrap;">${value}</div>`;

        case 'radio':
        case 'select':
            return `<strong>${value}</strong>`;

        default:
            return value;
    }
}

