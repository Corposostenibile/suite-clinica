// Function to load cronologia
async function loadCronologia() {
    const clienteId = {{ cliente.cliente_id }};
    const container = document.getElementById('cronologia-container');
    
    container.innerHTML = `
        <div class="text-center py-3">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Caricamento...</span>
            </div>
        </div>
    `;
    
    try {
        const response = await fetch(`/customers/${clienteId}/history/json`);
        if (!response.ok) throw new Error('Errore nel caricamento della cronologia');
        
        const data = await response.json();
        
        if (data.versions && data.versions.length > 0) {
            let html = '<div class="list-group">';
            
            data.versions.forEach((version, index) => {
                const changesList = version.changes ? Object.entries(version.changes)
                    .map(([field, values]) => `<li><strong>${field}:</strong> ${values.old} → ${values.new}</li>`)
                    .join('') : '';
                
                html += `
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-2">
                                    <span class="badge bg-primary me-2">v${version.version_num || index + 1}</span>
                                    <small class="text-muted">
                                        ${version.timestamp || 'Data non disponibile'}
                                        ${version.user ? `• ${version.user}` : ''}
                                    </small>
                                </div>
                                ${changesList ? `
                                    <div class="small">
                                        <strong>Modifiche:</strong>
                                        <ul class="mb-0 ps-3">
                                            ${changesList}
                                        </ul>
                                    </div>
                                ` : '<p class="mb-0 text-muted small">Nessun dettaglio disponibile</p>'}
                            </div>
                            ${version.can_restore ? `
                                <button class="btn btn-sm btn-outline-warning" 
                                        onclick="ripristinaVersione(${clienteId}, ${version.tx_id})">
                                    Ripristina
                                </button>
                            ` : ''}
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            container.innerHTML = html;
        } else {
            container.innerHTML = `
                <div class="alert alert-info">
                    Nessuna modifica registrata per questo cliente.
                </div>
