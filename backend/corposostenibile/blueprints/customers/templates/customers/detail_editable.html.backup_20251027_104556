/**
 * Disattiva il link permanente del check DCA
 */
function deactivateDCACheckLink(checkId, clienteId) {
    if (!confirm('Sei sicuro di voler disattivare questo link DCA? Il cliente non potrà più utilizzarlo per compilare il check.')) {
        return;
    }

    fetch(`/client-checks/dca/${checkId}/deactivate`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': '{{ csrf_token() }}'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Show success toast
            const toast = document.createElement('div');
            toast.className = 'alert alert-success position-fixed top-0 start-50 translate-minimum-x mt-3';
            toast.style.zIndex = '9999';
            toast.innerHTML = '<i class="ri-checkbox-circle-line me-2"></i>Link DCA disattivato con successo!';
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.remove();
                location.reload();  // Ricarica per aggiornare la vista
            }, 2000);
        } else {
            alert('Errore nella disattivazione: ' + (data.error || 'Errore sconosciuto'));
        }
    })
    .catch(err => {
        console.error('Errore:', err);
        alert('Errore nella disattivazione del link DCA');
    });
}

