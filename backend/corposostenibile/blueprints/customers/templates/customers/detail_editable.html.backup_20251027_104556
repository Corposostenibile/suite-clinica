                                                                                            <small class="text-muted d-block mb-1">Progresso</small>
                                                                                            <strong class="text-primary fs-5">{{ response.progress_rating }}/10</strong>
                                                                                        </div>
                                                                                    </div>
                                                                                    {% endif %}
                                                                                    {% if response.nutritionist_rating %}
                                                                                    <div class="col-4 col-md-3">
