                    <!-- TAB ATTIVITÀ -->
                    <div class="tab-pane fade" id="pills-attivita" role="tabpanel">
                        <!-- TICKETS SECTION -->
                        <h6 class="text-md text-primary-light mb-16">
                            <i class="bi bi-ticket-detailed me-2"></i>Ticket Associati
                        </h6>
                        {% if tickets %}
                            {% set visible_tickets = [] %}
                            {% for ticket in tickets %}
                                {# Mostra ticket solo se: creato da me, assegnato a me, o sono nel dipartimento #}
                                {% if current_user.is_admin or 
                                      ticket.created_by_id == current_user.id or 
                                      ticket.assigned_to_id == current_user.id or
                                      (ticket.department and ticket.department.id == current_user.department_id) or
                                      (ticket.department and ticket.department.head_id == current_user.id) %}
                                    {% set _ = visible_tickets.append(ticket) %}
                                {% endif %}
                            {% endfor %}
                            
                            {% if visible_tickets %}
                            <div class="list-group mb-4">
                                {% for ticket in visible_tickets %}
                                <a href="{{ url_for('ticket.detail', ticket_id=ticket.id) }}" 
                                   class="list-group-item list-group-item-action">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center mb-1">
                                                <span class="badge bg-primary me-2">#{{ ticket.ticket_number }}</span>
                                                {% if ticket.status.value == 'nuovo' %}
                                                    <span class="badge bg-danger">Nuovo</span>
                                                {% elif ticket.status.value == 'in_lavorazione' %}
                                                    <span class="badge bg-warning text-dark">In Lavorazione</span>
                                                {% elif ticket.status.value == 'in_attesa' %}
                                                    <span class="badge bg-info">In Attesa</span>
                                                {% elif ticket.status.value == 'chiuso' %}
                                                    <span class="badge bg-success">Chiuso</span>
                                                {% endif %}
                                                
                                                {% if ticket.urgency.value == '1' %}
                                                    <span class="badge bg-danger ms-1">🔴 Alta</span>
                                                {% elif ticket.urgency.value == '2' %}
                                                    <span class="badge bg-warning text-dark ms-1">🟡 Media</span>
                                                {% else %}
                                                    <span class="badge bg-success ms-1">🟢 Bassa</span>
                                                {% endif %}
                                            </div>
                                            <h6 class="mb-1">{{ ticket.title }}</h6>
                                            {% if ticket.description %}
                                                <p class="mb-1 text-muted small">{{ ticket.description[:100] }}{% if ticket.description|length > 100 %}...{% endif %}</p>
                                            {% endif %}
                                            <small class="text-muted">
                                                <i class="bi bi-calendar3 me-1"></i>
                                                Creato il {{ ticket.created_at.strftime('%d/%m/%Y %H:%M') }}
                                                {% if ticket.department %}
                                                    | <i class="bi bi-building me-1"></i>{{ ticket.department.name }}
                                                {% endif %}
                                            </small>
                                        </div>
                                        <div class="text-end">
                                            <i class="bi bi-chevron-right text-muted"></i>
                                        </div>
                                    </div>
                                </a>
                                {% endfor %}
                            </div>
                            {% else %}
                                <div class="alert alert-light border mb-4">
                                    <div class="text-center py-3">
                                        <i class="bi bi-ticket-detailed" style="font-size: 3rem; color: #dee2e6;"></i>
                                        <p class="text-muted mt-2 mb-0">Nessun ticket visibile per questo cliente</p>
                                    </div>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="alert alert-light border mb-4">
                                <div class="text-center py-3">
                                    <i class="bi bi-ticket-detailed" style="font-size: 3rem; color: #dee2e6;"></i>
                                    <p class="text-muted mt-2 mb-0">Nessun ticket associato a questo cliente</p>
                                </div>
                            </div>
                        {% endif %}
                        
                        <!-- TASKS SECTION -->
                        <h6 class="text-md text-primary-light mb-16 mt-4">
                            <i class="bi bi-list-task me-2"></i>Attività
                        </h6>
                        {% if tasks %}
                            <div class="list-group">
                                {% for task in tasks[:5] %}
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">{{ task.title }}</h6>
                                            {% if task.description %}
                                                <p class="mb-1 text-muted small">{{ task.description[:100] }}</p>
                                            {% endif %}
                                        </div>
                                        <span class="badge bg-secondary">
                                            {{ task.status.value if task.status else 'pending' }}
                                        </span>
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="alert alert-light border">
                                <div class="text-center py-3">
                                    <i class="bi bi-list-task" style="font-size: 3rem; color: #dee2e6;"></i>
                                    <p class="text-muted mt-2 mb-0">Nessuna attività assegnata</p>
                                </div>
                            </div>
                        {% endif %}
                    </div>

