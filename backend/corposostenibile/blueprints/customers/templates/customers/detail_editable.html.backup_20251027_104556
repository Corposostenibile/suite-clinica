                                    <i class="bi bi-bag-check me-2"></i>Check Sales
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="check2-iniziale-tab" data-bs-toggle="pill"
                                        data-bs-target="#check2-iniziale" type="button" role="tab">
                                    <i class="bi bi-clipboard-check me-2"></i>Check Iniziale
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="check2-settimanale-tab" data-bs-toggle="pill"
                                        data-bs-target="#check2-settimanale" type="button" role="tab">
                                    <i class="bi bi-calendar-check me-2"></i>Check Settimanale
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content" id="check2TabsContent">
                            <!-- TAB CHECK SALES -->
                            <div class="tab-pane fade show active" id="check2-sales" role="tabpanel">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="mb-0">Check Sales</h5>
                                        <small class="text-muted">Risposte al questionario compilato durante il processo di vendita</small>
                                    </div>
                                    <div class="card-body">
                                        {% set sales_assignments = check_assignments|selectattr('form.name', 'equalto', 'Check Sales')|list %}
                                        {% if sales_assignments %}
                                            {% for assignment in sales_assignments %}
                                                <div class="alert alert-info mb-3">
                                                    <i class="bi bi-info-circle me-2"></i>
                                                    <strong>Compilato da:</strong> {{ assignment.assigned_by.full_name if assignment.assigned_by else 'N/D' }}
                                                    <span class="ms-3"><strong>Data:</strong> {{ assignment.created_at.strftime('%d/%m/%Y %H:%M') }}</span>
                                                </div>

                                                {% if assignment.responses %}
                                                    <h6 class="mt-4 mb-3">Risposte ricevute ({{ assignment.responses|length }}):</h6>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-hover">
                                                            <thead>
                                                                <tr>
                                                                    <th>Data</th>
                                                                    <th>Azioni</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                {% for response in assignment.responses|sort(attribute='created_at', reverse=True) %}
                                                                <tr>
                                                                    <td>{{ response.created_at.strftime('%d/%m/%Y %H:%M') }}</td>
                                                                    <td>
                                                                        <button class="btn btn-sm btn-outline-primary"
                                                                                onclick="viewResponse({{ response.id }})">
                                                                            <i class="bi bi-eye me-1"></i>Visualizza
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                                {% endfor %}
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                {% else %}
                                                    <div class="alert alert-light border text-center py-4">
                                                        <i class="bi bi-clipboard-x" style="font-size: 3rem; color: #dee2e6;"></i>
                                                        <p class="text-muted mt-2 mb-0">Nessuna compilazione ancora ricevuta</p>
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                        {% else %}
                                            <div class="alert alert-light border text-center py-4">
                                                <i class="bi bi-bag-x" style="font-size: 3rem; color: #dee2e6;"></i>
                                                <p class="text-muted mt-2 mb-0">Nessun check sales disponibile</p>
                                                <small class="text-muted">Il cliente non ha compilato il questionario durante il processo di vendita</small>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <!-- TAB CHECK INIZIALE -->
                            <div class="tab-pane fade" id="check2-iniziale" role="tabpanel">
                                <div class="card">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <h5 class="mb-0">Check Iniziale</h5>
                                        {% if current_user.is_admin or current_user in [cliente.nutrizionista, cliente.coach, cliente.psicologo] %}
                                        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal"
                                                data-bs-target="#assignInitialCheckModal">
                                            <i class="bi bi-plus-circle me-1"></i>Assegna Check
                                        </button>
                                        {% endif %}
                                    </div>
                                    <div class="card-body">
                                        {% set initial_assignment = check_assignments|selectattr('form.form_type.value', 'equalto', 'iniziale')|rejectattr('form.name', 'equalto', 'Check Sales')|first %}
                                        {% if initial_assignment %}
                                            <div class="alert alert-info mb-3">
                                                <i class="bi bi-info-circle me-2"></i>
                                                <strong>Form assegnato:</strong> {{ initial_assignment.form.name }}
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label fw-semibold">Link di compilazione:</label>
                                                <div class="input-group">
                                                    <code class="form-control" id="initialCheckLink">{{ url_for('client_checks.public_form', token=initial_assignment.token, _external=True) }}</code>
                                                    <button class="btn btn-outline-secondary" type="button"
                                                            onclick="copyToClipboard('initialCheckLink')">
                                                        <i class="bi bi-clipboard"></i>
                                                    </button>
                                                </div>
                                            </div>

                                            {% if initial_assignment.responses %}
                                                <h6 class="mt-4 mb-3">Compilazioni ricevute ({{ initial_assignment.responses|length }}):</h6>
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-hover">
                                                        <thead>
                                                            <tr>
                                                                <th>Data</th>
                                                                <th>Azioni</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            {% for response in initial_assignment.responses|sort(attribute='created_at', reverse=True) %}
                                                            <tr>
                                                                <td>{{ response.created_at.strftime('%d/%m/%Y %H:%M') }}</td>
                                                                <td>
                                                                    <button class="btn btn-sm btn-outline-primary"
                                                                            onclick="viewResponse({{ response.id }})">
                                                                        <i class="bi bi-eye me-1"></i>Visualizza
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                            {% endfor %}
                                                        </tbody>
                                                    </table>
                                                </div>
                                            {% else %}
                                                <div class="alert alert-light border text-center py-4">
                                                    <i class="bi bi-clipboard-x" style="font-size: 3rem; color: #dee2e6;"></i>
                                                    <p class="text-muted mt-2 mb-0">Nessuna compilazione ancora ricevuta</p>
                                                </div>
                                            {% endif %}
                                        {% else %}
                                            <div class="alert alert-light border text-center py-4">
                                                <i class="bi bi-clipboard-plus" style="font-size: 3rem; color: #dee2e6;"></i>
                                                <p class="text-muted mt-2 mb-0">Nessun check iniziale assegnato</p>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <!-- TAB CHECK SETTIMANALE 2.0 -->
                            <div class="tab-pane fade" id="check2-settimanale" role="tabpanel">
                                <div class="card">
                                    {% set active_weekly_check = cliente.weekly_checks.filter_by(is_active=True).first() if cliente.weekly_checks else None %}
                                    {% set active_dca_check = cliente.dca_checks.filter_by(is_active=True).first() if cliente.dca_checks else None %}
                                    {% set active_check = active_weekly_check or active_dca_check %}
                                    {% set check_type = 'weekly' if active_weekly_check else 'dca' %}

                                    <div class="card-header bg-success bg-opacity-10">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h5 class="mb-0"><i class="ri-clipboard-line me-2"></i>Check Periodico</h5>
                                                <small class="text-muted">Check Regolare o Check DCA</small>
                                            </div>
                                            {% if (current_user.is_admin or current_user in [cliente.nutrizionista_user, cliente.coach_user, cliente.psicologo_user]) and not active_check %}
                                            <div class="d-flex gap-2 align-items-center">
                                                <select id="checkTypeSelect" class="form-select form-select-sm" style="width: auto;">
                                                    <option value="regular">Check Regolare</option>
                                                    <option value="dca">Check DCA</option>
                                                </select>
                                                <button type="button" class="btn btn-success btn-sm" onclick="generateCheckLink('{{ cliente.cliente_id }}')">
                                                    <i class="ri-add-circle-line me-1"></i>Genera Link
                                                </button>
                                            </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="card-body">

                                        {% if active_check %}
                                            <!-- LINK PERMANENTE ATTIVO - Compatto con Collapse -->
                                            <div class="mb-3">
                                                <a class="text-decoration-none" data-bs-toggle="collapse" href="#linkPermanenteCollapse" role="button" aria-expanded="false" aria-controls="linkPermanenteCollapse">
                                                    <div class="d-inline-flex align-items-center gap-2 p-2 px-3 rounded" style="background: #e8f5e9; cursor: pointer; transition: all 0.3s ease;">
                                                        <i class="ri-arrow-right-s-line text-success fw-bold" id="linkPermanenteChevron" style="font-size: 1.25rem; transition: transform 0.3s ease;"></i>
                                                        <i class="bi bi-link-45deg text-success"></i>
                                                        <span class="text-success small fw-semibold">Link Permanente Attivo</span>
                                                        {% if check_type == 'dca' %}
                                                            <span class="badge bg-warning text-dark">Check DCA</span>
                                                        {% else %}
                                                            <span class="badge bg-info text-white">Check Regolare</span>
                                                        {% endif %}
                                                        <span class="badge bg-success text-white">{{ active_check.response_count }} compilazioni</span>
                                                    </div>
                                                </a>

                                                <!-- Collapse Content -->
                                                <div class="collapse mt-2" id="linkPermanenteCollapse">
                                                    <div class="card border-0 shadow-sm">
                                                        <div class="card-body p-3">
                                                            <script>
                                                                // Rotazione freccia al toggle del collapse
                                                                document.getElementById('linkPermanenteCollapse').addEventListener('show.bs.collapse', function () {
                                                                    document.getElementById('linkPermanenteChevron').style.transform = 'rotate(90deg)';
                                                                });
                                                                document.getElementById('linkPermanenteCollapse').addEventListener('hide.bs.collapse', function () {
                                                                    document.getElementById('linkPermanenteChevron').style.transform = 'rotate(0deg)';
                                                                });
                                                            </script>
                                                            <div class="row g-2 mb-3">
                                                                <div class="col-md-4">
                                                                    <small class="text-muted d-block">Assegnato il</small>
                                                                    <strong class="text-dark">{{ active_check.assigned_at.strftime('%d/%m/%Y %H:%M') }}</strong>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <small class="text-muted d-block">Compilazioni</small>
                                                                    <strong class="text-dark">{{ active_check.response_count }}</strong>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <small class="text-muted d-block">Ultima risposta</small>
                                                                    <strong class="text-dark">
                                                                        {% if active_check.last_response_date %}
                                                                            {{ active_check.last_response_date.strftime('%d/%m/%Y %H:%M') }}
