                                 style="width: 200px; height: 200px; background: #f8f9fa; border-radius: 15px; border: 3px solid #e3e6f0; padding: 5px;">
                                <img src="{{ latest_photo|image_url }}"
                                     alt="Foto profilo"
                                     style="max-width: 100%; max-height: 100%; object-fit: contain;">
                            </div>
                            <small class="text-muted d-block mt-2">
                                Ultimo aggiornamento: {{ latest_date.strftime('%d/%m/%Y') if latest_date else 'N/D' }}
                            </small>
                        {% else %}
