    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="changeLocationModalLabel">
                    <i class="ri-edit-line me-2"></i>
                    Modifica Luogo Allenamento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="change_location_form">
                    <input type="hidden" id="change_location_id">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Data Inizio <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="change_location_start_date" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Data Fine</label>
                            <input type="date" class="form-control" id="change_location_end_date">
                            <small class="form-text text-muted">Lascia vuoto se ancora attivo</small>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Luogo <span class="text-danger">*</span></label>
                        <select class="form-control" id="change_location_location" required>
                            <option value="">Seleziona luogo</option>
                            <option value="casa">CASA</option>
                            <option value="palestra">PALESTRA</option>
                            <option value="ibrido">IBRIDO</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" id="change_location_notes" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Motivazione Modifica</label>
                        <textarea class="form-control" id="change_location_reason" rows="2" placeholder="Descrivi il motivo della modifica..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                <button type="button" class="btn btn-primary" onclick="saveChangeLocation()">
                    <i class="ri-save-line me-1"></i> Salva Modifiche
                </button>
            </div>
        </div>
    </div>
</div>

<script>
// ========================================================================
// GESTIONE DIETE - Sistema Storico
// ========================================================================
(function() {
    const clienteId = {{ cliente.cliente_id }};
    const csrfToken = "{{ csrf_token() }}";

    // Carica piano dieta attivo
    async function loadActiveDietPlan() {
        try {
            const response = await fetch(`/customers/${clienteId}/diet/history`);
            const data = await response.json();

            const container = document.getElementById('diet-plan-container');
            if (!container) return;

            const activePlan = data.plans.find(p => p.is_active);
            const legacyPlan = data.plans.find(p => p.is_legacy);

            if (activePlan) {
                container.innerHTML = renderActivePlan(activePlan, data.can_manage);
            } else if (legacyPlan) {
                container.innerHTML = renderLegacyPlan(legacyPlan, data.can_manage);
            } else {
                container.innerHTML = `
                    <div class="alert alert-info">
                        <i class="ri-information-line"></i> Nessun piano dieta attivo.
                        ${data.can_manage ? '<button type="button" class="btn btn-primary btn-sm mt-2" onclick="openAddDietModal()"><i class="ri-add-line me-1"></i> Aggiungi Prima Dieta</button>' : ''}
                    </div>
                `;
            }
        } catch (error) {
            console.error('Errore caricamento piano dieta:', error);
            const container = document.getElementById('diet-plan-container');
            if (container) {
                container.innerHTML = `<div class="alert alert-danger"><i class="ri-error-warning-line"></i> Errore nel caricamento</div>`;
            }
        }
    }

    // Render piano attivo
    function renderActivePlan(plan, canManage) {
        const startDate = plan.start_date ? new Date(plan.start_date).toLocaleDateString('it-IT') : '-';
        const endDate = plan.end_date ? new Date(plan.end_date).toLocaleDateString('it-IT') : '-';

        return `
            <div class="row g-3">
                <div class="col-md-12">
                    <label class="modern-form-label">Nome Piano</label>
                    <input type="text" class="form-control modern-form-control" value="${escapeHtml(plan.name || '')}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="modern-form-label">Dieta Dal</label>
                    <input type="text" class="form-control modern-form-control" value="${startDate}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="modern-form-label">Dieta Fino Al</label>
                    <input type="text" class="form-control modern-form-control" value="${endDate}" readonly>
                </div>
                <div class="col-12">
                    <label class="modern-form-label">Piano Alimentare</label>
                    <textarea class="form-control modern-form-control" rows="4" readonly>${escapeHtml(plan.piano_alimentare || '')}</textarea>
                </div>
            </div>
            ${canManage ? `
                <div class="mt-3 d-flex gap-2">
                    <button type="button" class="btn btn-primary btn-sm" onclick="openAddDietModal()">
                        <i class="ri-add-line me-1"></i> Aggiungi Nuova Dieta
                    </button>
                    <button type="button" class="btn btn-secondary btn-sm" onclick="openChangeDietModal(${plan.id})">
                        <i class="ri-edit-2-line me-1"></i> Modifica Piano Attuale
                    </button>
                </div>
            ` : ''}
        `;
    }

    // Render piano legacy
    function renderLegacyPlan(plan, canManage) {
        const startDate = plan.start_date ? new Date(plan.start_date).toLocaleDateString('it-IT') : '-';
        const endDate = plan.end_date ? new Date(plan.end_date).toLocaleDateString('it-IT') : '-';

        return `
            <div class="alert alert-warning mb-3">
                <i class="ri-alert-line"></i> <strong>Dati Legacy</strong> - Questi dati provengono dalla vecchia gestione
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="modern-form-label">Dieta Dal</label>
                    <input type="text" class="form-control modern-form-control" value="${startDate}" readonly>
                </div>
                <div class="col-md-6">
                    <label class="modern-form-label">Nuova Dieta Dal</label>
                    <input type="text" class="form-control modern-form-control" value="${endDate}" readonly>
                </div>
                <div class="col-12">
                    <label class="modern-form-label">Piano Alimentare</label>
                    <textarea class="form-control modern-form-control" rows="4" readonly>${escapeHtml(plan.piano_alimentare || '')}</textarea>
                </div>
            </div>
            ${canManage ? `
                <div class="mt-3">
                    <button type="button" class="btn btn-primary btn-sm" onclick="openAddDietModal()">
                        <i class="ri-add-line me-1"></i> Inizia Nuovo Sistema Diete
                    </button>
                </div>
            ` : ''}
        `;
    }

    // Carica storico diete
    async function loadDietHistory() {
        try {
            const response = await fetch(`/customers/${clienteId}/diet/history`);
            const data = await response.json();

            const container = document.getElementById('diet-history-container');
            if (!container) return;

            if (!data.plans || data.plans.length === 0) {
                container.innerHTML = `
                    <div class="text-center text-muted py-4">
                        <i class="ri-inbox-line" style="font-size: 3rem;"></i>
                        <p class="mt-3">Nessuno storico disponibile</p>
                    </div>
                `;
                return;
            }

            let html = '<div class="table-responsive"><table class="table table-hover table-sm">';
            html += '<thead><tr><th>Periodo</th><th>Stato</th><th>Tipo</th><th>Piano</th><th>Note</th><th>Azioni</th></tr></thead><tbody>';

            data.plans.forEach(plan => {
                const startDate = plan.start_date ? new Date(plan.start_date).toLocaleDateString('it-IT') : '-';
                const endDate = plan.end_date ? new Date(plan.end_date).toLocaleDateString('it-IT') : '-';

                let statusBadge = plan.is_legacy ? '<span class="badge bg-warning">Legacy</span>' :
                                 plan.is_active ? '<span class="badge bg-success">Attivo</span>' :
                                 '<span class="badge bg-secondary">Chiuso</span>';

                const pianoCut = (plan.piano_alimentare || '').substring(0, 50);
                const pianoText = pianoCut + (plan.piano_alimentare && plan.piano_alimentare.length > 50 ? '...' : '');

                html += `<tr>
                    <td>${startDate} → ${endDate}</td>
                    <td>${statusBadge}</td>
                    <td>${escapeHtml(plan.tipo_attuale || '-')}</td>
                    <td title="${escapeHtml(plan.piano_alimentare || '')}">${escapeHtml(pianoText)}</td>
                    <td>${escapeHtml((plan.notes || '').substring(0, 30))}</td>
                    <td>
                        ${!plan.is_legacy && data.can_manage ? `<button class="btn btn-sm btn-outline-secondary" onclick="openChangeDietModal(${plan.id})"><i class="ri-edit-2-line"></i></button>` : ''}
                    </td>
                </tr>`;
            });

            html += '</tbody></table></div>';
            container.innerHTML = html;
        } catch (error) {
            console.error('Errore:', error);
            const container = document.getElementById('diet-history-container');
            if (container) container.innerHTML = `<div class="alert alert-danger">Errore caricamento</div>`;
        }
    }

    // Open Add Diet Modal
    window.openAddDietModal = function() {
        // Clear form manually instead of reset() to avoid triggering events
        document.getElementById('add_diet_name').value = '';
        document.getElementById('add_diet_start_date').value = '';
        document.getElementById('add_diet_end_date').value = '';
        document.getElementById('add_diet_piano_alimentare').value = '';
        document.getElementById('add_diet_notes').value = '';

        fetch(`/customers/${clienteId}/diet/history`)
            .then(r => r.json())
            .then(data => {
                const activePlan = data.plans.find(p => p.is_active);
                const startInput = document.getElementById('add_diet_start_date');
                if (activePlan && activePlan.end_date) {
                    const endDate = new Date(activePlan.end_date);
                    endDate.setDate(endDate.getDate() + 1);
                    startInput.value = endDate.toISOString().split('T')[0];
                } else {
                    startInput.value = new Date().toISOString().split('T')[0];
                }
            })
            .catch(() => { document.getElementById('add_diet_start_date').value = new Date().toISOString().split('T')[0]; });
        new bootstrap.Modal(document.getElementById('addDietModal')).show();
    };

    // Save Add Diet
    window.saveAddDiet = async function() {
        const form = document.getElementById('addDietForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const payload = {
            name: document.getElementById('add_diet_name').value,
            start_date: document.getElementById('add_diet_start_date').value,
            end_date: document.getElementById('add_diet_end_date').value,
            piano_alimentare: document.getElementById('add_diet_piano_alimentare').value,
            notes: document.getElementById('add_diet_notes').value,
        };

        try {
            const response = await fetch(`/customers/${clienteId}/diet/add`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRFToken': csrfToken },
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('addDietModal')).hide();
                alert('Dieta aggiunta con successo!');
                loadActiveDietPlan();
                loadDietHistory();
            } else {
                alert('Errore: ' + (result.error || 'Impossibile salvare'));
            }
        } catch (error) {
            console.error(error);
            alert('Errore durante il salvataggio');
        }
    };

    // Open Change Diet Modal
    window.openChangeDietModal = async function(planId) {
        try {
            const response = await fetch(`/customers/${clienteId}/diet/history`);
            const data = await response.json();
            const plan = data.plans.find(p => p.id === planId);
            if (!plan) { alert('Piano non trovato'); return; }

            document.getElementById('change_diet_plan_id').value = plan.id;
            document.getElementById('change_diet_start_date').value = plan.start_date || '';
            document.getElementById('change_diet_end_date').value = plan.end_date || '';
            document.getElementById('change_diet_piano_alimentare').value = plan.piano_alimentare || '';
            document.getElementById('change_diet_notes').value = plan.notes || '';
            document.getElementById('change_diet_reason').value = '';

            new bootstrap.Modal(document.getElementById('changeDietModal')).show();
        } catch (error) {
            console.error(error);
            alert('Errore caricamento piano');
        }
    };

    // Save Change Diet
    window.saveChangeDiet = async function() {
        const planId = document.getElementById('change_diet_plan_id').value;
        const payload = {
            plan_id: parseInt(planId),
            start_date: document.getElementById('change_diet_start_date').value,
            end_date: document.getElementById('change_diet_end_date').value,
            piano_alimentare: document.getElementById('change_diet_piano_alimentare').value,
            notes: document.getElementById('change_diet_notes').value,
            change_reason: document.getElementById('change_diet_reason').value,
        };

        try {
            const response = await fetch(`/customers/${clienteId}/diet/change`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRFToken': csrfToken },
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (response.ok) {
                bootstrap.Modal.getInstance(document.getElementById('changeDietModal')).hide();
                alert('Piano aggiornato!');
                loadActiveDietPlan();
                loadDietHistory();
            } else {
                alert('Errore: ' + (result.error || 'Impossibile aggiornare'));
            }
        } catch (error) {
            console.error(error);
            alert('Errore durante il salvataggio');
        }
    };

    // Escape HTML
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // Init - carica dati quando disponibili
    function initDietManagement() {
        if (document.getElementById('diet-plan-container')) {
            loadActiveDietPlan();
            loadDietHistory();
        }
    }

    // Carica al DOMContentLoaded
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initDietManagement);
    } else {
        // DOM già caricato
        initDietManagement();
    }

    // Rilancia quando il tab nutrizione setup viene mostrato
    document.addEventListener('shown.bs.tab', function(event) {
        if (event.target.getAttribute('href') === '#nutr-setup' ||
            event.target.getAttribute('data-bs-target') === '#nutr-setup') {
            initDietManagement();
        }
    });
})();

</script>
{% endblock %}