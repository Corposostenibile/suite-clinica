{# Freeze Banner (sempre visibile se cliente è in freeze) #}
{% if cliente.is_frozen %}
<div class="alert alert-danger d-flex align-items-center mb-3" style="border-left: 5px solid #dc3545;">
    <iconify-icon icon="ri:lock-fill" class="icon text-xl me-3" style="color: #dc3545;"></iconify-icon>
    <div class="flex-grow-1">
        <h5 class="mb-1">🔒 CLIENTE IN STATO FREEZE</h5>
        <p class="mb-1"><strong>Tutte le attività sono sospese</strong> - NON programmare call o sessioni</p>
        {% if cliente.freeze_reason %}
        <p class="mb-0"><small><strong>Motivazione:</strong> {{ cliente.freeze_reason }}</small></p>
        {% endif %}
        {% if cliente.freeze_date %}
        <p class="mb-0"><small><strong>Dal:</strong> {{ cliente.freeze_date.strftime('%d/%m/%Y %H:%M') }}</small></p>
        {% endif %}
    </div>
</div>
{% endif %}

{# Alert Banner per Scadenze - Calcolo sempre dinamico #}
{% set giorni = cliente.giorni_rimanenti_calcolati %}
{% if giorni is not none %}
    {% if giorni < 0 %}
        {# Già scaduto #}
        <div class="alert alert-danger d-flex align-items-center mb-24" role="alert">
            <iconify-icon icon="ri:error-warning-fill" class="icon text-xl me-2"></iconify-icon>
            <div>
                <strong>ATTENZIONE: Abbonamento SCADUTO!</strong>
                L'abbonamento di {{ cliente.nome_cognome }} è scaduto da <strong>{{ -giorni }} {% if -giorni == 1 %}giorno{% else %}giorni{% endif %}</strong> 
                (data scadenza: {{ cliente.data_rinnovo.strftime('%d/%m/%Y') if cliente.data_rinnovo else 'N/D' }}).
                È necessario contattare urgentemente il cliente per il rinnovo.
            </div>
        </div>
    {% elif giorni == 0 %}
        {# Scade oggi #}
        <div class="alert alert-danger d-flex align-items-center mb-24" role="alert">
            <iconify-icon icon="ri:error-warning-fill" class="icon text-xl me-2"></iconify-icon>
            <div>
                <strong>ATTENZIONE: Abbonamento in SCADENZA OGGI!</strong>
                L'abbonamento di {{ cliente.nome_cognome }} <strong>scade oggi</strong> 
                ({{ cliente.data_rinnovo.strftime('%d/%m/%Y') if cliente.data_rinnovo else 'N/D' }}).
                Contattare immediatamente il cliente per il rinnovo.
            </div>
        </div>
    {% elif giorni <= 10 %}
        {# Scade entro 10 giorni #}
        <div class="alert alert-danger d-flex align-items-center mb-24" role="alert">
            <iconify-icon icon="ri:alarm-warning-fill" class="icon text-xl me-2"></iconify-icon>
            <div>
                <strong>URGENTE: Scadenza imminente!</strong>
                L'abbonamento scade tra <strong>{{ giorni }} giorni</strong> 
                ({{ cliente.data_rinnovo.strftime('%d/%m/%Y') if cliente.data_rinnovo else 'N/D' }}).
                Contattare il cliente per il rinnovo.
            </div>
        </div>
    {% elif giorni <= 30 %}
        {# Scade entro 1 mese #}
        <div class="alert alert-warning d-flex align-items-center mb-24" role="alert">
            <iconify-icon icon="ri:calendar-check-fill" class="icon text-xl me-2"></iconify-icon>
            <div>
                <strong>Promemoria: Rinnovo in arrivo</strong>
                L'abbonamento scade tra <strong>{{ giorni }} giorni</strong> 
                ({{ cliente.data_rinnovo.strftime('%d/%m/%Y') if cliente.data_rinnovo else 'N/D' }}).
                Pianificare il contatto per il rinnovo.
            </div>
        </div>
    {% endif %}
{% endif %}

<div class="row g-3 align-items-start">
    <!-- Left Sidebar Info -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body p-24">
                <div class="text-center mb-24">
                    <div class="mb-16">
                        <!-- Mostra l'ultima foto frontale: priorità check settimanali -> typeform -> nulla -->
                        {% set latest_photo = None %}
                        {% set latest_date = None %}

                        {# Cerca ultima foto nei check settimanali #}
                        {% if cliente.weekly_checks or cliente.dca_checks %}
                            {% set all_checks = [] %}
                            {% if cliente.weekly_checks %}
                                {% for check in cliente.weekly_checks %}
                                    {% for response in check.responses %}
                                        {% if response.photo_front %}
                                            {% set _ = all_checks.append(response) %}
                                        {% endif %}
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}
                            {% if cliente.dca_checks %}
                                {% for check in cliente.dca_checks %}
                                    {% for response in check.responses %}
                                        {% if response.photo_front %}
                                            {% set _ = all_checks.append(response) %}
                                        {% endif %}
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}
                            {% if all_checks|length > 0 %}
                                {% set latest_check = all_checks|sort(attribute='submit_date', reverse=true)|first %}
                                {% set latest_photo = latest_check.photo_front %}
                                {% set latest_date = latest_check.submit_date %}
                            {% endif %}
                        {% endif %}

                        {# Se non trovata nei check, cerca in typeform_responses #}
                        {% if not latest_photo and cliente.typeform_responses and cliente.typeform_responses|length > 0 %}
                            {% set latest_response = cliente.typeform_responses|sort(attribute='submit_date', reverse=true)|first %}
                            {% if latest_response.photo_front %}
                                {% set latest_photo = latest_response.photo_front %}
                                {% set latest_date = latest_response.submit_date %}
                            {% endif %}
                        {% endif %}

                        {# Mostra l'immagine #}
