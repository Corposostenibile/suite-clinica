<script>
// Store CSRF token from Flask template
const CSRF_TOKEN = "{{ csrf_token() }}";

// Form management
function resetForm(formId) {
    document.getElementById(formId).reset();
}

// Professional field management
function addProfessionalField(type) {
    const container = document.getElementById(type + '-container');
    const existingFields = container.querySelectorAll('.professional-field');
    
    // Get the options from the first select
    const firstSelect = existingFields[0].querySelector('select');
    const optionsHtml = firstSelect.innerHTML;
    
    // Create new field
    const newField = document.createElement('div');
    newField.className = 'professional-field mb-2';
    newField.innerHTML = `
        <div class="input-group">
            <select class="form-control radius-8 form-select" name="${type}_ids[]">
                ${optionsHtml}
            </select>
            <button type="button" class="btn btn-danger" onclick="removeProfessionalField(this)">
                <i class="ri-delete-bin-line"></i>
            </button>
        </div>
    `;
    
    container.appendChild(newField);
}

function removeProfessionalField(button) {
    const field = button.closest('.professional-field');
    const container = field.parentElement;

    // Keep at least one field
    if (container.querySelectorAll('.professional-field').length > 1) {
        field.remove();
    } else {
        // If it's the last field, just clear the selection
        field.querySelector('select').value = '';
    }
}

// ========================================
// TAB RESTORATION - Mantiene le tab attive dopo il reload
// ========================================
document.addEventListener('DOMContentLoaded', function() {
    // Ripristina le tab salvate in sessionStorage dopo il reload
    const savedMainTab = sessionStorage.getItem('activeMainTab');
    const savedSubTab = sessionStorage.getItem('activeSubTab');

    // Ripristina la tab principale
    if (savedMainTab) {
        console.log('Ripristino tab principale:', savedMainTab);

        // Cerca le nav-pills principali (non quelle con mb-4)
        const mainNavPills = document.querySelector('.nav-pills:not(.mb-4)');
        if (mainNavPills) {
            // Rimuovi active da tutte le tab principali
            mainNavPills.querySelectorAll('.nav-link').forEach(tab => {
                tab.classList.remove('active');
            });
        }

        // Rimuovi active da tutti i tab-pane principali
        const mainTabContent = document.getElementById('pills-tabContent');
        if (mainTabContent) {
            mainTabContent.querySelectorAll(':scope > .tab-pane').forEach(pane => {
                pane.classList.remove('show', 'active');
            });
        }

        // Attiva la tab salvata
        const mainTabButton = document.querySelector(`.nav-pills:not(.mb-4) .nav-link[data-bs-target="${savedMainTab}"], .nav-pills:not(.mb-4) .nav-link[href="${savedMainTab}"]`);
        const mainTabPane = document.querySelector(savedMainTab);

        if (mainTabButton && mainTabPane) {
            mainTabButton.classList.add('active');
            mainTabPane.classList.add('show', 'active');
            console.log('Tab principale ripristinata con successo');
        } else {
            console.warn('Impossibile trovare tab principale:', savedMainTab);
        }

        // Pulisci il valore salvato
        sessionStorage.removeItem('activeMainTab');
    }

    // Ripristina la sotto-tab (dopo un piccolo delay per assicurarsi che la tab principale sia caricata)
    if (savedSubTab) {
        setTimeout(() => {
            console.log('Ripristino sotto-tab:', savedSubTab);

            // Trova la tab principale attiva
            const activeMainPane = document.querySelector('.tab-pane.show.active');
            if (!activeMainPane) {
                console.warn('Nessuna tab principale attiva trovata');
                sessionStorage.removeItem('activeSubTab');
                return;
            }

            // Cerca le sotto-tab solo all'interno della tab principale attiva
            const subNavPills = activeMainPane.querySelector('.nav-pills.mb-4');
            if (subNavPills) {
                // Rimuovi active da tutte le sotto-tab
                subNavPills.querySelectorAll('.nav-link').forEach(tab => {
                    tab.classList.remove('active');
                });
            }

            // Attiva la sotto-tab salvata
            const subTabButton = activeMainPane.querySelector(`.nav-pills.mb-4 .nav-link[data-bs-target="${savedSubTab}"], .nav-pills.mb-4 .nav-link[href="${savedSubTab}"]`);
            const subTabPane = activeMainPane.querySelector(savedSubTab);

            if (subTabButton && subTabPane) {
                // Rimuovi active da tutti i pane delle sotto-tab all'interno di questa tab principale
                const parentTabContent = subTabPane.closest('.tab-content');
                if (parentTabContent) {
                    parentTabContent.querySelectorAll('.tab-pane').forEach(pane => {
                        pane.classList.remove('show', 'active');
                    });
                }

                subTabButton.classList.add('active');
                subTabPane.classList.add('show', 'active');
                console.log('Sotto-tab ripristinata con successo');
            } else {
                console.warn('Impossibile trovare sotto-tab:', savedSubTab);
            }

            // Pulisci il valore salvato
            sessionStorage.removeItem('activeSubTab');
        }, 100);
    }
});

// ========================================
// PROFESSION FIELD MANAGEMENT - Dropdown + Notes
// ========================================

document.addEventListener('DOMContentLoaded', function() {
    const professioneSelect = document.getElementById('professione-select');
    const altroContainer = document.getElementById('professione-altro-container');
    const altroInput = document.getElementById('professione-altro-input');
    const professioneNoteInput = document.getElementById('professione-note-input');

    if (professioneSelect) {
        // Handle profession select change
        professioneSelect.addEventListener('change', function() {
            if (this.value === '__ALTRO__') {
                altroContainer.style.display = 'block';
                altroInput.required = true;
                altroInput.focus();
            } else {
                altroContainer.style.display = 'none';
                altroInput.required = false;
                altroInput.value = '';
            }
        });

        // Load existing profession value and notes (TWO SEPARATE FIELDS)
        const existingProfession = professioneSelect.dataset.professioneEsistente;
        const existingNotes = professioneSelect.dataset.professioneNoteEsistente;

        // Carica NOTE sempre se presenti
        if (existingNotes && existingNotes.trim() !== '' && professioneNoteInput) {
            professioneNoteInput.value = existingNotes;
            console.log('Note professione caricate:', existingNotes.substring(0, 50) + '...');
        }

        // Carica PROFESSIONE se presente
        if (existingProfession && existingProfession.trim() !== '') {
            // Cerca match nel dropdown
            let optionFound = false;
            for (let option of professioneSelect.options) {
                if (option.value === existingProfession) {
                    option.selected = true;
                    optionFound = true;
                    console.log('Professione trovata nel dropdown:', existingProfession);
                    break;
                }
            }

            // Se non trovata, seleziona "Altro" e popola input custom
            if (!optionFound && existingProfession !== '__ALTRO__') {
                professioneSelect.value = '__ALTRO__';
                altroContainer.style.display = 'block';
                altroInput.value = existingProfession;
                altroInput.required = true;
                console.log('Professione custom caricata:', existingProfession);
            }
        }
    }

    // Handle form submission for profession field (TWO SEPARATE FIELDS)
    const formAnagrafica = document.getElementById('form-anagrafica');
    if (formAnagrafica) {
        formAnagrafica.addEventListener('submit', function(e) {
            const professioneSelect = document.getElementById('professione-select');
            const altroInput = document.getElementById('professione-altro-input');
            const professioneNoteInput = document.getElementById('professione-note-input');

            let professionValue = '';
            let notesValue = '';

            // Get professione value
            if (professioneSelect && professioneSelect.value === '__ALTRO__') {
                // If "Altro" is selected, use the custom input value
                if (altroInput && altroInput.value.trim()) {
                    professionValue = altroInput.value.trim();
                } else {
                    e.preventDefault();
                    alert('Per favore, specifica la professione nel campo "Altro".');
                    altroInput.focus();
                    return false;
                }
            } else if (professioneSelect && professioneSelect.value) {
                professionValue = professioneSelect.value;
            }

            // Get notes value (SEPARATE!)
            if (professioneNoteInput && professioneNoteInput.value.trim()) {
                notesValue = professioneNoteInput.value.trim();
            }

            // Create hidden inputs for BOTH fields separately
            // Remove any existing hidden inputs
            const existingHidden = formAnagrafica.querySelector('input[name="professione"][type="hidden"]');
            if (existingHidden) {
                existingHidden.remove();
            }
            const existingHiddenNotes = formAnagrafica.querySelector('input[name="professione_note"][type="hidden"]');
            if (existingHiddenNotes) {
                existingHiddenNotes.remove();
            }

            // Add professione hidden input
            if (professionValue) {
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'professione';
                hiddenInput.value = professionValue;
                formAnagrafica.appendChild(hiddenInput);
            }

            // Add professione_note hidden input
            if (notesValue) {
                const hiddenInputNotes = document.createElement('input');
                hiddenInputNotes.type = 'hidden';
                hiddenInputNotes.name = 'professione_note';
                hiddenInputNotes.value = notesValue;
                formAnagrafica.appendChild(hiddenInputNotes);
            }

            // Remove the name attributes from visible fields to avoid conflict
            if (professioneSelect) {
                professioneSelect.removeAttribute('name');
            }
            if (professioneNoteInput) {
                professioneNoteInput.removeAttribute('name');
            }
        });
    }
});

