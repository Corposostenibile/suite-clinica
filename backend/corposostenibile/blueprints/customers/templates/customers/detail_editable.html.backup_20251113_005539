/**
 * Genera un nuovo link per Check Periodico (Regolare o DCA)
 */
function generateCheckLink(clienteId) {
    const checkType = document.getElementById('checkTypeSelect').value;
    const url = checkType === 'dca'
        ? `/client-checks/dca/generate/${clienteId}`
        : `/client-checks/weekly/generate/${clienteId}`;

    // Show loading state
    const button = event.target;
    const originalHtml = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generando...';

    // Send POST request
    fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': CSRF_TOKEN
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Show success message
            const toast = document.createElement('div');
            toast.className = 'alert alert-success position-fixed top-0 start-50 translate-middle-x mt-3';
            toast.style.zIndex = '9999';
            toast.innerHTML = `
                <i class="ri-checkbox-circle-line me-2"></i>
                Link Check ${checkType === 'dca' ? 'DCA' : 'Regolare'} generato con successo!
                <button type="button" class="btn-close ms-3" onclick="this.parentElement.remove()"></button>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.remove();
                // Reload page to show new check
                location.reload();
            }, 2000);
        } else {
            alert('Errore nella generazione del link: ' + (data.error || 'Errore sconosciuto'));
            button.disabled = false;
            button.innerHTML = originalHtml;
        }
    })
    .catch(error => {
        console.error('Errore:', error);
        alert('Errore nella generazione del link');
        button.disabled = false;
        button.innerHTML = originalHtml;
    });
}

