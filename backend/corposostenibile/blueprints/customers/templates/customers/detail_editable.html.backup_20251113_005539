/* ============================================
   PATOLOGIE CHECKBOX CARDS - Modern Design
   ============================================ */

.patologia-card {
    position: relative;
    border: 2px solid #E2E8F0;
    border-radius: 12px;
    padding: 16px 20px;
    background: #FFFFFF;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 60px;
}

.patologia-card:hover {
    border-color: #45CB85;
    background: #F0FDF4;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(69, 203, 133, 0.15);
}

.patologia-card .form-check-input {
    width: 22px;
    height: 22px;
    border: 2.5px solid #CBD5E1;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.25s ease;
    flex-shrink: 0;
    margin: 0;
}

.patologia-card .form-check-input:hover {
    border-color: #45CB85;
    box-shadow: 0 0 0 4px rgba(69, 203, 133, 0.1);
}

.patologia-card .form-check-input:checked {
    background-color: #45CB85;
    border-color: #45CB85;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20'%3e%3cpath fill='none' stroke='%23fff' stroke-linecap='round' stroke-linejoin='round' stroke-width='3' d='M6 10l3 3l6-6'/%3e%3c/svg%3e");
    box-shadow: 0 0 0 4px rgba(69, 203, 133, 0.2);
}

.patologia-card .form-check-input:focus {
    box-shadow: 0 0 0 4px rgba(69, 203, 133, 0.25);
    border-color: #45CB85;
}

.patologia-card .form-check-label {
    font-size: 15px;
    font-weight: 500;
    color: #334155;
    cursor: pointer;
    margin: 0;
    flex-grow: 1;
    user-select: none;
    transition: color 0.2s ease;
}

.patologia-card:hover .form-check-label {
    color: #239957;
}

/* Stato checked della card */
.patologia-card:has(.form-check-input:checked) {
    background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);
    border-color: #45CB85;
    border-width: 2.5px;
    box-shadow: 0 4px 16px rgba(69, 203, 133, 0.2);
}

.patologia-card:has(.form-check-input:checked) .form-check-label {
    color: #166534;
    font-weight: 600;
}

/* Icona decorativa quando checked */
.patologia-card::after {
    content: '✓';
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%) scale(0);
    font-size: 20px;
    color: #45CB85;
    font-weight: bold;
    opacity: 0;
    transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.patologia-card:has(.form-check-input:checked)::after {
    transform: translateY(-50%) scale(1);
    opacity: 1;
}

/* Animazione pulse quando si seleziona */
@keyframes pulseGreen {
    0% {
        box-shadow: 0 0 0 0 rgba(69, 203, 133, 0.4);
    }
    70% {
        box-shadow: 0 0 0 10px rgba(69, 203, 133, 0);
    }
    100% {
        box-shadow: 0 0 0 0 rgba(69, 203, 133, 0);
    }
}

.patologia-card .form-check-input:checked {
    animation: pulseGreen 0.5s;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .patologia-card {
        padding: 14px 16px;
        min-height: 56px;
    }

    .patologia-card .form-check-label {
        font-size: 14px;
    }
}

