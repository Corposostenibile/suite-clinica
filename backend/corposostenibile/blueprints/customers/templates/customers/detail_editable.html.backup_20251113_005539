                        <ul class="nav nav-pills mb-4" id="checkTabs2" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="check2-check1-tab" data-bs-toggle="pill"
                                        data-bs-target="#check2-check1" type="button" role="tab">
                                    <i class="bi bi-1-circle me-2"></i>Check 1
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="check2-check2-tab" data-bs-toggle="pill"
