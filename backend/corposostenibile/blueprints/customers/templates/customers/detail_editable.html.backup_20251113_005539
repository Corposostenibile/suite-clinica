// Function to merge metrics data from TypeForm and Weekly Checks
function mergeMetricsData(typeformData, weeklyData) {
    // If no data from either source
    if (!typeformData.has_data && !weeklyData.has_data) {
        return { has_data: false };
    }

    // Combine labels (dates) from both sources and sort chronologically
    let allLabels = [];
    if (typeformData.labels) allLabels = allLabels.concat(typeformData.labels);
    if (weeklyData.labels) allLabels = allLabels.concat(weeklyData.labels);

    // Remove duplicates and sort
    allLabels = [...new Set(allLabels)].sort((a, b) => new Date(a) - new Date(b));

    // Initialize merged metrics
    const mergedMetrics = {};
    const metricKeys = ['weight', 'digestion', 'energy', 'strength', 'hunger', 'sleep', 'mood', 'motivation', 'progress'];

    metricKeys.forEach(key => {
        const typeformMetric = typeformData.metrics?.[key] || {};
        const weeklyMetric = weeklyData.metrics?.[key] || {};

        // Ensure data arrays exist
        const typeformDataArr = typeformMetric.data || [];
        const weeklyDataArr = weeklyMetric.data || [];
        const typeformLabels = typeformData.labels || [];
        const weeklyLabels = weeklyData.labels || [];

        // Merge data arrays for each metric
        const mergedData = allLabels.map(label => {
            const typeformIndex = typeformLabels.indexOf(label);
            const weeklyIndex = weeklyLabels.indexOf(label);

            let value = null;

            // Priority: Weekly Checks > TypeForm (newer data wins)
            if (weeklyIndex !== -1 && weeklyDataArr[weeklyIndex] !== null && weeklyDataArr[weeklyIndex] !== undefined) {
                value = weeklyDataArr[weeklyIndex];
            } else if (typeformIndex !== -1 && typeformDataArr[typeformIndex] !== null && typeformDataArr[typeformIndex] !== undefined) {
                value = typeformDataArr[typeformIndex];
            }

            return value;
        });

        mergedMetrics[key] = {
            label: typeformMetric.label || weeklyMetric.label || key.charAt(0).toUpperCase() + key.slice(1),
            data: mergedData,
            color: typeformMetric.color || weeklyMetric.color || '#888888'
        };
    });

    // Merge weight data if available
    let weightData = [];
    if (typeformData.weight_data) weightData = weightData.concat(typeformData.weight_data);
    if (weeklyData.weight_data) weightData = weeklyData.concat(weeklyData.weight_data);

    // Sort by date
    weightData.sort((a, b) => new Date(a.date) - new Date(b.date));

    return {
        has_data: true,
        labels: allLabels,
        metrics: mergedMetrics,
        weight_data: weightData,
        typeform_count: typeformData.typeform_count || 0,
        weekly_count: weeklyData.weekly_count || 0
    };
}

