// Function to load cronologia
async function loadCronologia() {
    const clienteId = {{ cliente.cliente_id }};
    const timeline = document.getElementById('cronologia-timeline');
    const noCronologiaDiv = document.getElementById('no-cronologia');

    timeline.innerHTML = `
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Caricamento...</span>
            </div>
            <p class="text-muted mt-2 mb-0">Caricamento cronologia...</p>
        </div>
    `;

    try {
        const response = await fetch(`/customers/${clienteId}/history/json`);
        if (!response.ok) throw new Error('Errore nel caricamento della cronologia');

        const data = await response.json();

        if (data.versions && data.versions.length > 0) {
            noCronologiaDiv.style.display = 'none';
            timeline.style.display = 'block';
            timeline.innerHTML = '';

            data.versions.forEach((version, index) => {
                const isLast = index === data.versions.length - 1;
                const versionNum = version.version_num || (data.versions.length - index);
                const dotColor = '#28a745'; // Green color for modifications
                const cardBorderColor = 'rgba(40, 167, 69, 0.2)';
                const lineColor = '#e9ecef';

                // Get user initials for avatar fallback
                const userName = version.user || 'Sistema';
                const userInitials = userName.split(' ')
                    .map(n => n[0])
                    .join('')
                    .toUpperCase()
                    .substring(0, 2);

                // Build changes list
                let changesHtml = '';
                if (version.changes && Object.keys(version.changes).length > 0) {
                    changesHtml = '<div class="mt-3">';
                    Object.entries(version.changes).forEach(([field, values]) => {
                        changesHtml += `
                            <div class="mb-2 p-2" style="background: #f8f9fa; border-radius: 8px; border-left: 3px solid ${dotColor};">
                                <div class="d-flex align-items-start">
                                    <i class="ri-arrow-right-line me-2" style="color: ${dotColor}; flex-shrink: 0; margin-top: 2px;"></i>
                                    <div class="flex-grow-1">
                                        <strong style="color: #495057; font-size: 0.85rem;">${field}</strong>
                                        <div style="color: #6c757d; font-size: 0.85rem; margin-top: 2px;">
                                            <span style="text-decoration: line-through; opacity: 0.7;">${values.old || 'N/D'}</span>
                                            →
                                            <span style="color: ${dotColor}; font-weight: 500;">${values.new || 'N/D'}</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    changesHtml += '</div>';
                }

                const actions = version.can_restore
                    ? `<button class="btn btn-sm btn-warning" onclick="ripristinaVersione(${clienteId}, ${version.tx_id})" style="border-radius: 20px;">
                           <i class="ri-history-line me-1"></i>Ripristina
                       </button>`
                    : '';

                // Avatar HTML - use avatar URL if available, otherwise show initials
                const avatarHtml = version.user_avatar_url
                    ? `<img src="${version.user_avatar_url}" alt="${userName}" style="width: 56px; height: 56px; object-fit: cover; border-radius: 50%; border: 3px solid ${dotColor}; box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);">`
                    : `<div style="width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, ${dotColor} 0%, #20c997 100%); border: 3px solid ${dotColor}; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);">
                           <span style="font-size: 1.2rem; font-weight: 600; color: white;">${userInitials}</span>
                       </div>`;

                const item = `
                    <div class="timeline-item" style="position: relative; padding-bottom: ${isLast ? '0' : '2.5rem'}; animation: fadeInUp 0.5s ease ${index * 0.1}s both;">
                        <!-- Timeline Line -->
                        ${!isLast ? `<div style="position: absolute; left: 28px; top: 80px; bottom: 0; width: 3px; background: linear-gradient(180deg, ${lineColor} 0%, ${lineColor}00 100%);"></div>` : ''}

                        <!-- Main Content -->
                        <div class="d-flex gap-3">
                            <!-- User Avatar -->
                            <div style="position: relative; flex-shrink: 0;">
                                ${avatarHtml}
                            </div>

                            <!-- Card Content -->
                            <div class="flex-grow-1">
                                <div class="card" style="border: 2px solid ${cardBorderColor}; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transition: all 0.3s ease;" onmouseover="this.style.boxShadow='0 8px 30px rgba(0,0,0,0.12)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='0 4px 20px rgba(0,0,0,0.08)'; this.style.transform='translateY(0)'">
                                    <!-- Card Header with gradient -->
                                    <div style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); padding: 1rem; color: white;">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h5 class="mb-1" style="font-weight: 600; color: white;">${userName}</h5>
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="ri-calendar-line"></i>
                                                    <span style="font-size: 0.9rem;">${version.timestamp || 'Data non disponibile'}</span>
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge" style="background: rgba(255,255,255,0.3); backdrop-filter: blur(10px); padding: 6px 12px; border-radius: 20px; font-size: 0.85rem;">
                                                    <i class="ri-edit-line me-1"></i>v${versionNum}
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Card Body -->
                                    <div class="card-body p-3">
                                        ${changesHtml || '<p class="text-muted mb-0"><i class="ri-information-line me-2"></i>Nessun dettaglio disponibile</p>'}

                                        <!-- Footer -->
                                        ${actions ? `
                                            <div class="d-flex justify-content-end pt-3 mt-3" style="border-top: 1px solid #e9ecef;">
                                                ${actions}
                                            </div>
                                        ` : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;

                timeline.innerHTML += item;
            });
        } else {
            noCronologiaDiv.style.display = 'block';
            timeline.style.display = 'none';
        }
    } catch (error) {
        console.error('Error loading cronologia:', error);
        timeline.innerHTML = `
            <div class="alert alert-danger">
                <i class="ri-error-warning-line me-2"></i>
                Errore nel caricamento della cronologia: ${error.message}
            </div>
        `;
    }
}

// Function to restore a version
async function ripristinaVersione(clienteId, txId) {
    if (!confirm('Sei sicuro di voler ripristinare questa versione? Le modifiche attuali verranno sovrascritte.')) {
        return;
    }
    
    try {
        const response = await fetch(`/customers/${clienteId}/history/${txId}/restore`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCSRFToken(),
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({})
        });
        
        const data = await response.json();
        
        if (response.ok && data.success) {
            alert(data.message || 'Versione ripristinata con successo!');
            window.location.reload();
        } else {
            console.error('Restore error:', data);
            alert(data.error || 'Errore nel ripristino della versione');
        }
    } catch (error) {
        console.error('Error restoring version:', error);
        alert('Errore di connessione: ' + error.message);
    }
}

