                                                {% if current_user.is_admin or current_user in [cliente.nutrizionista_user, cliente.coach_user, cliente.psicologa_user] or current_user in cliente.nutrizionisti_multipli or current_user in cliente.coaches_multipli or current_user in cliente.psicologi_multipli %}
