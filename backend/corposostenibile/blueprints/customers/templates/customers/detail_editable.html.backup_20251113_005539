                            <small class="form-text text-muted">Lascia vuoto se ancora attivo</small>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Luogo <span class="text-danger">*</span></label>
                        <select class="form-control" id="add_location_location" required>
                            <option value="">Seleziona luogo</option>
                            <option value="casa">CASA</option>
                            <option value="palestra">PALESTRA</option>
                            <option value="ibrido">IBRIDO</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" id="add_location_notes" rows="2"></textarea>
