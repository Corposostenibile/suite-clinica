                                    <i class="bi bi-3-circle me-2"></i>Check 3
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="check2-settimanale-tab" data-bs-toggle="pill"
                                        data-bs-target="#check2-settimanale" type="button" role="tab">
                                    <i class="bi bi-calendar-check me-2"></i>Check Settimanale
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content" id="check2TabsContent">
                            <!-- TAB CHECK 1 -->
                            <div class="tab-pane fade show active" id="check2-check1" role="tabpanel">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="mb-0"><i class="bi bi-1-circle me-2"></i>Check 1</h5>
                                        <small class="text-muted">Dati anagrafici e informazioni base compilati durante il Sales Form</small>
                                    </div>
                                    <div class="card-body">
                                        {% set check1_assignments = check_assignments|selectattr('form.name', 'equalto', 'Check 1')|list %}
                                        {% if check1_assignments %}
                                            {% for assignment in check1_assignments %}
                                                <div class="alert alert-info mb-3">
                                                    <i class="bi bi-info-circle me-2"></i>
                                                    <strong>Compilato il:</strong> {{ assignment.created_at.strftime('%d/%m/%Y %H:%M') }}
                                                </div>

                                                {% if assignment.responses %}
                                                    <h6 class="mt-4 mb-3">Risposte:</h6>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-hover">
                                                            <tbody>
                                                                {% for response in assignment.responses|sort(attribute='created_at', reverse=True) %}
                                                                <tr>
                                                                    <td>{{ response.created_at.strftime('%d/%m/%Y %H:%M') }}</td>
                                                                    <td>
                                                                        <button class="btn btn-sm btn-outline-primary"
                                                                                onclick="viewResponse({{ response.id }})">
                                                                            <i class="bi bi-eye me-1"></i>Visualizza
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                                {% endfor %}
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                        {% else %}
                                            <div class="alert alert-light border text-center py-4">
                                                <i class="bi bi-clipboard-x" style="font-size: 3rem; color: #dee2e6;"></i>
                                                <p class="text-muted mt-2 mb-0">Nessun Check 1 disponibile</p>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <!-- TAB CHECK 2 -->
                            <div class="tab-pane fade" id="check2-check2" role="tabpanel">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="mb-0"><i class="bi bi-2-circle me-2"></i>Check 2</h5>
                                        <small class="text-muted">File e documenti caricati durante il Sales Form</small>
                                    </div>
                                    <div class="card-body">
                                        {% set check2_assignments = check_assignments|selectattr('form.name', 'equalto', 'Check 2')|list %}
                                        {% if check2_assignments %}
                                            {% for assignment in check2_assignments %}
                                                <div class="alert alert-info mb-3">
                                                    <i class="bi bi-info-circle me-2"></i>
                                                    <strong>Compilato il:</strong> {{ assignment.created_at.strftime('%d/%m/%Y %H:%M') }}
                                                </div>

                                                {% if assignment.responses %}
                                                    <h6 class="mt-4 mb-3">Risposte:</h6>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-hover">
                                                            <tbody>
                                                                {% for response in assignment.responses|sort(attribute='created_at', reverse=True) %}
                                                                <tr>
                                                                    <td>{{ response.created_at.strftime('%d/%m/%Y %H:%M') }}</td>
                                                                    <td>
                                                                        <button class="btn btn-sm btn-outline-primary"
                                                                                onclick="viewResponse({{ response.id }})">
                                                                            <i class="bi bi-eye me-1"></i>Visualizza
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                                {% endfor %}
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                        {% else %}
                                            <div class="alert alert-light border text-center py-4">
                                                <i class="bi bi-clipboard-x" style="font-size: 3rem; color: #dee2e6;"></i>
                                                <p class="text-muted mt-2 mb-0">Nessun Check 2 disponibile</p>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <!-- TAB CHECK 3 -->
                            <div class="tab-pane fade" id="check2-check3" role="tabpanel">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="mb-0"><i class="bi bi-3-circle me-2"></i>Check 3</h5>
                                        <small class="text-muted">Questionario psico-alimentare con tipo calcolato</small>
                                    </div>
                                    <div class="card-body">
                                        {% set check3_assignments = check_assignments|selectattr('form.name', 'equalto', 'Check 3')|list %}
                                        {% if check3_assignments %}
                                            {% for assignment in check3_assignments %}
                                                <div class="alert alert-info mb-3">
                                                    <i class="bi bi-info-circle me-2"></i>
                                                    <strong>Compilato il:</strong> {{ assignment.created_at.strftime('%d/%m/%Y %H:%M') }}
                                                    {% if cliente.tipo_iniziale %}
                                                        <span class="ms-3"><strong>Tipo:</strong> <span class="badge bg-primary">{{ cliente.tipo_iniziale }}</span></span>
                                                    {% endif %}
                                                </div>

                                                {% if assignment.responses %}
                                                    <h6 class="mt-4 mb-3">Risposte:</h6>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-hover">
                                                            <tbody>
                                                                {% for response in assignment.responses|sort(attribute='created_at', reverse=True) %}
                                                                <tr>
                                                                    <td>{{ response.created_at.strftime('%d/%m/%Y %H:%M') }}</td>
                                                                    <td>
                                                                        <button class="btn btn-sm btn-outline-primary"
                                                                                onclick="viewResponse({{ response.id }})">
                                                                            <i class="bi bi-eye me-1"></i>Visualizza
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                                {% endfor %}
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                        {% else %}
                                            <div class="alert alert-light border text-center py-4">
                                                <i class="bi bi-clipboard-x" style="font-size: 3rem; color: #dee2e6;"></i>
                                                <p class="text-muted mt-2 mb-0">Nessun Check 3 disponibile</p>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <!-- TAB CHECK SETTIMANALE 2.0 -->
                            <div class="tab-pane fade" id="check2-settimanale" role="tabpanel">
                                <div class="card">
                                    {% set active_weekly_check = cliente.weekly_checks.filter_by(is_active=True).first() if cliente.weekly_checks else None %}
                                    {% set active_dca_check = cliente.dca_checks.filter_by(is_active=True).first() if cliente.dca_checks else None %}
                                    {% set active_check = active_weekly_check or active_dca_check %}
                                    {% set check_type = 'weekly' if active_weekly_check else 'dca' %}

                                    {# TUTTE le risposte (attive E disattivate) per mostrare sempre lo storico #}
                                    {% set all_weekly_responses = [] %}
                                    {% if cliente.weekly_checks %}
                                        {% for check in cliente.weekly_checks.all() %}
                                            {% for resp in check.responses.all() %}
                                                {% if all_weekly_responses.append(resp) %}{% endif %}
                                            {% endfor %}
                                        {% endfor %}
                                    {% endif %}
                                    {% if cliente.dca_checks %}
                                        {% for check in cliente.dca_checks.all() %}
                                            {% for resp in check.responses.all() %}
                                                {% if all_weekly_responses.append(resp) %}{% endif %}
                                            {% endfor %}
                                        {% endfor %}
                                    {% endif %}
                                    {# Ordina per data decrescente #}
                                    {% set all_weekly_responses = all_weekly_responses|sort(attribute='submit_date', reverse=True) %}

                                    <div class="card-header bg-success bg-opacity-10">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h5 class="mb-0"><i class="ri-clipboard-line me-2"></i>Check Periodico</h5>
                                                <small class="text-muted">Check Regolare o Check DCA</small>
                                            </div>
                                            {% if (current_user.is_admin or current_user in [cliente.nutrizionista_user, cliente.coach_user, cliente.psicologa_user] or current_user in cliente.nutrizionisti_multipli or current_user in cliente.coaches_multipli or current_user in cliente.psicologi_multipli) and not active_check %}
                                            <div class="d-flex gap-2 align-items-center">
                                                <select id="checkTypeSelect" class="form-select form-select-sm" style="width: auto;">
                                                    <option value="regular">Check Regolare</option>
                                                    <option value="dca">Check DCA</option>
                                                </select>
                                                <button type="button" class="btn btn-success btn-sm" onclick="generateCheckLink('{{ cliente.cliente_id }}')">
                                                    <i class="ri-add-circle-line me-1"></i>Genera Link
                                                </button>
                                            </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="card-body">

                                        {% if active_check %}
                                            <!-- LINK PERMANENTE ATTIVO - Compatto con Collapse -->
                                            <div class="mb-3">
                                                <a class="text-decoration-none" data-bs-toggle="collapse" href="#linkPermanenteCollapse" role="button" aria-expanded="false" aria-controls="linkPermanenteCollapse">
                                                    <div class="d-inline-flex align-items-center gap-2 p-2 px-3 rounded" style="background: #e8f5e9; cursor: pointer; transition: all 0.3s ease;">
                                                        <i class="ri-arrow-right-s-line text-success fw-bold" id="linkPermanenteChevron" style="font-size: 1.25rem; transition: transform 0.3s ease;"></i>
                                                        <i class="bi bi-link-45deg text-success"></i>
                                                        <span class="text-success small fw-semibold">Link Permanente Attivo</span>
                                                        {% if check_type == 'dca' %}
                                                            <span class="badge bg-warning text-dark">Check DCA</span>
                                                        {% else %}
                                                            <span class="badge bg-info text-white">Check Regolare</span>
                                                        {% endif %}
                                                        <span class="badge bg-success text-white">{{ all_weekly_responses|length }} compilazioni totali</span>
                                                    </div>
                                                </a>

                                                <!-- Collapse Content -->
                                                <div class="collapse mt-2" id="linkPermanenteCollapse">
                                                    <div class="card border-0 shadow-sm">
                                                        <div class="card-body p-3">
                                                            <script>
                                                                // Rotazione freccia al toggle del collapse
                                                                document.getElementById('linkPermanenteCollapse').addEventListener('show.bs.collapse', function () {
                                                                    document.getElementById('linkPermanenteChevron').style.transform = 'rotate(90deg)';
                                                                });
                                                                document.getElementById('linkPermanenteCollapse').addEventListener('hide.bs.collapse', function () {
                                                                    document.getElementById('linkPermanenteChevron').style.transform = 'rotate(0deg)';
                                                                });
                                                            </script>
                                                            <div class="row g-2 mb-3">
                                                                <div class="col-md-4">
                                                                    <small class="text-muted d-block">Assegnato il</small>
                                                                    <strong class="text-dark">{{ active_check.assigned_at.strftime('%d/%m/%Y %H:%M') }}</strong>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <small class="text-muted d-block">Compilazioni Totali</small>
                                                                    <strong class="text-dark">{{ all_weekly_responses|length }}</strong>
                                                                </div>
                                                                <div class="col-md-4">
                                                                    <small class="text-muted d-block">Ultima risposta</small>
                                                                    <strong class="text-dark">
                                                                        {% if active_check.last_response_date %}
                                                                            {{ active_check.last_response_date.strftime('%d/%m/%Y %H:%M') }}
                                                                        {% else %}
                                                                            -
                                                                        {% endif %}
                                                                    </strong>
                                                                </div>
                                                            </div>

                                                            <div class="mb-2">
                                                                <small class="text-muted d-block mb-1">Token</small>
                                                                <div class="input-group input-group-sm">
                                                                    <input type="text" class="form-control" value="{{ active_check.token }}" readonly style="font-family: monospace; font-size: 0.75rem;">
                                                                    <button class="btn btn-outline-secondary" type="button"
                                                                            onclick="navigator.clipboard.writeText('{{ active_check.token }}');
                                                                                    const btn = this;
                                                                                    const orig = btn.innerHTML;
                                                                                    btn.innerHTML = '<i class=\'bi bi-check\'></i>';
                                                                                    setTimeout(() => btn.innerHTML = orig, 1500);">
                                                                        <i class="bi bi-clipboard"></i>
                                                                    </button>
                                                                </div>
                                                            </div>

                                                            <div class="d-flex gap-2 mt-3">
                                                                {% if check_type == 'dca' %}
                                                                    <button class="btn btn-success btn-sm flex-grow-1"
                                                                            onclick="copyWeeklyCheckLink('{{ url_for('client_checks.dca_check_public', token=active_check.token, _external=True) }}')">
                                                                        <i class="bi bi-link-45deg me-1"></i>Copia Link
                                                                    </button>
                                                                    <button class="btn btn-outline-danger btn-sm"
                                                                            onclick="if(confirm('Disattivare il link?')) deactivateDCACheckLink({{ active_check.id }}, '{{ cliente.cliente_id }}')">
                                                                        <i class="bi bi-x-circle me-1"></i>Disattiva
                                                                    </button>
                                                                {% else %}
                                                                    <button class="btn btn-success btn-sm flex-grow-1"
                                                                            onclick="copyWeeklyCheckLink('{{ url_for('client_checks.weekly_check_public', token=active_check.token, _external=True) }}')">
                                                                        <i class="bi bi-link-45deg me-1"></i>Copia Link
                                                                    </button>
                                                                    <button class="btn btn-outline-danger btn-sm"
                                                                            onclick="if(confirm('Disattivare il link?')) deactivateCheckLink({{ active_check.id }}, '{{ cliente.cliente_id }}')">
                                                                        <i class="bi bi-x-circle me-1"></i>Disattiva
                                                                    </button>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- COMPILAZIONI RICEVUTE (TUTTE - inclusi link disattivati) -->
                                            {% if all_weekly_responses|length > 0 %}
                                                <div class="alert alert-info mb-3">
                                                    <i class="bi bi-info-circle me-2"></i>
                                                    <strong>Totale compilazioni ricevute:</strong> {{ all_weekly_responses|length }}
                                                    {% if not active_check %}
                                                        <span class="badge bg-warning text-dark ms-2">Link non attivo - Storico</span>
                                                    {% endif %}
                                                </div>
                                                {% for response in all_weekly_responses %}
                                                <div class="feedback-card">
                                                    <div class="feedback-header">
                                                        <div>
                                                            <h6 class="mb-1">{{ response.submit_date.strftime('%d/%m/%Y') if response.submit_date else 'Data sconosciuta' }}</h6>
                                                            {% if response.weight or response.energy_rating %}
                                                            <small class="text-muted">
                                                                {% if response.weight %}Peso: {{ response.weight }}kg{% endif %}
                                                                {% if response.energy_rating %}{% if response.weight %} • {% endif %}Energia: {{ response.energy_rating }}/10{% endif %}
                                                            </small>
                                                            {% endif %}
                                                        </div>

                                                        <div class="feedback-ratings">
                                                            {% if can_see_nutrition_ratings and response.nutritionist_rating %}
                                                            {% set nutrizionista = cliente.nutrizionisti_multipli[0] if cliente.nutrizionisti_multipli else cliente.nutrizionista_user %}
                                                            <div class="rating-item">
                                                                {% if nutrizionista and nutrizionista.avatar_path %}
                                                                    <img src="{{ url_for('team.serve_avatar', user_id=nutrizionista.id, filename=nutrizionista.avatar_path) }}"
                                                                         alt="{{ nutrizionista.full_name }}" class="rating-icon rounded-circle">
                                                                {% else %}
                                                                    <iconify-icon icon="fluent-emoji-flat:green-salad" class="rating-icon"></iconify-icon>
                                                                {% endif %}
                                                                {{ rating_badge(response.nutritionist_rating, false) }}
                                                            </div>
                                                            {% endif %}

                                                            {% if can_see_psychology_ratings and response.psychologist_rating %}
                                                            {% set psicologo = cliente.psicologi_multipli[0] if cliente.psicologi_multipli else cliente.psicologa_user %}
                                                            <div class="rating-item">
                                                                {% if psicologo and psicologo.avatar_path %}
                                                                    <img src="{{ url_for('team.serve_avatar', user_id=psicologo.id, filename=psicologo.avatar_path) }}"
                                                                         alt="{{ psicologo.full_name }}" class="rating-icon rounded-circle">
                                                                {% else %}
                                                                    <iconify-icon icon="material-icon-theme:brainfuck" class="rating-icon"></iconify-icon>
                                                                {% endif %}
