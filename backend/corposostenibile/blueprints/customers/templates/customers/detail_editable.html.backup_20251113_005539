// Render history timeline
function renderHistoryTable() {
    const timeline = document.getElementById('history-timeline');
    const noHistoryDiv = document.getElementById('no-history');

    timeline.innerHTML = '';

    if (teamHistory.length === 0) {
        noHistoryDiv.style.display = 'block';
        timeline.style.display = 'none';
        return;
    }

    noHistoryDiv.style.display = 'none';
    timeline.style.display = 'block';

    // Ordina per data (più recente prima)
    const sortedHistory = [...teamHistory].sort((a, b) => {
        if (!a.data_dal && !b.data_dal) return 0;
        if (!a.data_dal) return 1;
        if (!b.data_dal) return -1;
        const dateA = new Date(a.data_dal.split('/').reverse().join('-'));
        const dateB = new Date(b.data_dal.split('/').reverse().join('-'));
        return dateB - dateA;
    });

    sortedHistory.forEach((prof, index) => {
        const typeInfo = professionalTypes[prof.tipo_professionista] || { label: prof.tipo_professionista, icon: 'ri-user-line' };
        const hasHistory = prof.has_history;
        const isLast = index === sortedHistory.length - 1;

        // Trova i dati completi del professionista per ottenere la foto
        let professionalData = null;
        const tipo = prof.tipo_professionista;
        if (tipo === 'nutrizionista') {
            professionalData = professionalsData.nutrizionisti.find(p => p.id === prof.professionista_id);
        } else if (tipo === 'coach') {
            professionalData = professionalsData.coaches.find(p => p.id === prof.professionista_id);
        } else if (tipo === 'psicologa') {
            professionalData = professionalsData.psicologi.find(p => p.id === prof.professionista_id);
        } else if (tipo === 'consulente') {
            professionalData = professionalsData.consulenti.find(p => p.id === prof.professionista_id);
