{#  Macro helpers                                                      #}
{# ------------------------------------------------------------------- #}
{% macro format_date(dt) -%}
  {{ dt.strftime('%d/%m/%Y') if dt else '—' }}
{%- endmacro %}

{% macro format_datetime(dt) -%}
  {{ dt.strftime('%d/%m/%Y %H:%M') if dt else '—' }}
{%- endmacro %}

{% macro format_bool(val) -%}
  {% if val is none %}<span class="bool-unknown">Non specificato</span>
  {% elif val %}<span class="bool-yes">✓ Sì</span>
  {% else %}<span class="bool-no">✗ No</span>{% endif %}
{%- endmacro %}

{% macro format_enum(val) -%}
  {{ val.value if val else '—' }}
{%- endmacro %}

{% macro format_text(val, max_length=none) -%}
  {% if not val %}
    <span class="empty">Non compilato</span>
  {% elif max_length and val|length > max_length %}
    {{ val[:max_length] }}...
  {% else %}
    {{ val }}
  {% endif %}
{%- endmacro %}

