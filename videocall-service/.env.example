# dTelecom Video Call Service
# Get your API keys at: https://cloud.dtelecom.org
DTELECOM_API_KEY=your-api-key-here
DTELECOM_API_SECRET=your-api-secret-here
VIDEOCALL_SERVICE_PORT=3100

# Optional: webhook URL (use ngrok for local testing)
# DTELECOM_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/api/video-calls/webhook
